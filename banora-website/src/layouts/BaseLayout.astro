---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ChatbotWidget from '../components/integrations/ChatbotWidget.astro';
import ChatbotBooking from '../components/integrations/ChatbotBooking.astro';
import BookingModal from '../components/integrations/BookingModal.astro';
import '../styles/global.css';
import { clinic } from '../data/clinic';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  schema?: object;
  ogImage?: string;
  chatbotVariant?: 'standard' | 'booking';
  noindex?: boolean;
  lcpImage?: string;
  lcpImageSrcset?: string;
}

const { title, description, canonicalUrl, schema, ogImage, chatbotVariant = 'booking', noindex = false, lcpImage, lcpImageSrcset } = Astro.props;
const siteUrl = clinic.website;
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImg = ogImage || `${siteUrl}/images/og-default.jpg`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Chiropractic',
  name: clinic.name,
  image: `${siteUrl}/images/clinic-adjustment-wide.webp`,
  telephone: clinic.phone,
  url: siteUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: clinic.address.street,
    addressLocality: clinic.address.suburb,
    addressRegion: clinic.address.state,
    postalCode: clinic.address.postcode,
    addressCountry: 'AU',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: clinic.geo.latitude,
    longitude: clinic.geo.longitude,
  },
  openingHoursSpecification: clinic.hoursSchema.map((h) => {
    const [day, time] = h.split(' ');
    const [opens, closes] = time.split('-');
    return {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: day === 'Mo' ? 'Monday' : day === 'Tu' ? 'Tuesday' : day === 'We' ? 'Wednesday' : day === 'Th' ? 'Thursday' : day === 'Fr' ? 'Friday' : 'Saturday',
      opens,
      closes,
    };
  }),
  priceRange: '$$',
  paymentAccepted: clinic.payment.join(', '),
};
---

<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Google Tag Manager (deferred — loads on first interaction or 3.5s fallback) -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function loadGTM() {
      if (window.gtmLoaded) return;
      window.gtmLoaded = true;
      window.dataLayer.push({'gtm.start': new Date().getTime(), event: 'gtm.js'});
      var j = document.createElement('script');
      j.async = true;
      j.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-5LMM3FS3';
      document.head.appendChild(j);
    }
    ['click','touchstart','mousemove','keydown','scroll'].forEach(function(e) {
      window.addEventListener(e, loadGTM, {once: true, passive: true});
    });
    setTimeout(loadGTM, 3500);
  </script>
  <!-- End Google Tag Manager -->
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={clinic.name} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts: self-hosted via @fontsource, inlined in CSS bundle — no external DNS lookups -->

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- LocalBusiness Schema (every page) -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <!-- Page-specific schema -->
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  <!-- LCP image preload (passed by page for above-the-fold hero images) -->
  {lcpImage && !lcpImageSrcset && <link rel="preload" as="image" href={lcpImage} fetchpriority="high" />}
  {lcpImage && lcpImageSrcset && <link rel="preload" as="image" href={lcpImage} imagesrcset={lcpImageSrcset} imagesizes="100vw" fetchpriority="high" />}

</head>
<body class="bg-white text-dark-text">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5LMM3FS3"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <Header />
  <main class="pb-16 lg:pb-0">
    <slot />
  </main>
  <Footer />

  <!-- Booking Modal (site-wide) -->
  <BookingModal />

  <!-- Chatbot Widget -->
  {chatbotVariant === 'booking' ? <ChatbotBooking /> : <ChatbotWidget />}

  <!-- Conversion tracking: phone clicks & booking link clicks -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    document.addEventListener('click', function(e) {
      var link = e.target.closest('a[href]');
      if (!link) return;
      var href = link.getAttribute('href') || '';
      if (href.startsWith('tel:')) {
        window.dataLayer.push({ event: 'phone_click', phone_number: href.replace('tel:', '') });
      }
      if (href.includes('iconpractice.com')) {
        window.dataLayer.push({ event: 'book_appointment', method: 'direct_link' });
      }
    });
  </script>
</body>
</html>
