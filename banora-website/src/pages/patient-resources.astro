---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic, pricing } from '../data/clinic';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Patient Forms & Resources | Banora Chiropractic',
  url: `${clinic.website}/patient-resources`,
};

const formPhases = [
  {
    title: 'Initial Consultation',
    description: 'Your first visit form — health history, current symptoms, and what you hope to achieve with care.',
    href: '/forms/initial-consultation.html',
    icon: '📋',
    badge: '45 min visit',
    color: 'from-[#1e3f6b] to-[#4a90c4]',
  },
  {
    title: 'Relief Care',
    description: 'Track your progress during the relief phase — pain levels, mobility changes, and how you are feeling.',
    href: '/forms/relief-care.html',
    icon: '🩺',
    badge: 'Phase 1',
    color: 'from-[#1e6b4a] to-[#2e9e6a]',
  },
  {
    title: 'Rehab Phase',
    description: 'As you move into corrective care, this form helps us monitor strength, stability, and function.',
    href: '/forms/rehab-phase.html',
    icon: '💪',
    badge: 'Phase 2',
    color: 'from-[#5a2d82] to-[#8b4db8]',
  },
  {
    title: 'Wellness',
    description: 'For ongoing wellness patients — a quick check-in to keep your care on track long-term.',
    href: '/forms/wellness.html',
    icon: '🌿',
    badge: 'Phase 3',
    color: 'from-[#1a6b5a] to-[#2a9e85]',
  },
];
---

<BaseLayout
  title="Patient Forms & Resources | Banora Chiropractic | Tweed Heads South"
  description="Access your patient forms online before your visit to Banora Chiropractic. Initial consultation, relief care, rehab, and wellness phase forms available digitally."
  schema={schema}
>

  <style>
    :root {
      --color-gold: #D4A853;
      --color-gold-light: #E8C97D;
      --color-gold-dark: #B88E3A;
      --color-warm-bg: #FFFBF3;
      --color-warm-bg-alt: #FFF8EB;
    }
  </style>

  <!-- ========== HERO ========== -->
  <section class="bg-[var(--color-warm-bg)] py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">For Our Patients</span>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-navy mt-3 mb-5">Patient Forms & Resources</h1>
      <p class="text-grey-text text-lg leading-relaxed max-w-2xl mx-auto">
        Save time at your appointment by completing your forms online before you arrive. Simply choose your form below, fill it in on your phone or computer, and submit.
      </p>
    </div>
  </section>

  <!-- ========== WHAT ARE THESE FORMS ========== -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">How It Works</span>
          <h2 class="font-[family-name:var(--font-display)] text-3xl font-semibold text-navy mt-3 mb-5">What Are These Forms?</h2>
          <p class="text-grey-text leading-relaxed mb-4">
            At Banora Chiropractic, your care follows a structured pathway. Each phase has its own form that helps us understand where you are in your journey and tailor your care accordingly.
          </p>
          <p class="text-grey-text leading-relaxed mb-4">
            If this is your <strong class="text-navy">first visit</strong>, start with the Initial Consultation form. Your chiropractor will guide you on which form to complete at each stage of your care.
          </p>
          <p class="text-grey-text leading-relaxed">
            All forms are submitted securely and reviewed by your practitioner before your appointment.
          </p>
        </div>
        <div class="bg-[var(--color-warm-bg)] rounded-2xl p-8 border border-[var(--color-gold)]/15">
          <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-4">The Phases of Care</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white text-sm font-semibold">1</div>
              <div>
                <p class="text-navy font-semibold text-sm">Initial Consultation</p>
                <p class="text-grey-text text-xs">Your first assessment and treatment</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white text-sm font-semibold">2</div>
              <div>
                <p class="text-navy font-semibold text-sm">Relief Care</p>
                <p class="text-grey-text text-xs">Reducing pain and restoring movement</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white text-sm font-semibold">3</div>
              <div>
                <p class="text-navy font-semibold text-sm">Rehab Phase</p>
                <p class="text-grey-text text-xs">Strengthening and correcting the cause</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-8 h-8 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white text-sm font-semibold">4</div>
              <div>
                <p class="text-navy font-semibold text-sm">Wellness</p>
                <p class="text-grey-text text-xs">Maintaining your results long-term</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FORM CARDS ========== -->
  <section class="py-16 md:py-24 bg-[var(--color-warm-bg)]">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">Online Forms</span>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mt-3 mb-4">Choose Your Form</h2>
        <p class="text-grey-text leading-relaxed">Not sure which form to complete? If this is your first visit, start with the Initial Consultation form.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {formPhases.map((form) => (
          <a href={form.href} class="group bg-white rounded-2xl overflow-hidden border border-[var(--color-gold)]/15 hover:border-[var(--color-gold)]/40 hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
            <div class="p-6">
              <div class="flex items-start gap-4">
                <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${form.color} flex items-center justify-center text-2xl shrink-0`}>
                  {form.icon}
                </div>
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy group-hover:text-[#2C5F8A] transition-colors">{form.title}</h3>
                  </div>
                  <p class="text-grey-text text-sm leading-relaxed">{form.description}</p>
                </div>
              </div>
            </div>
            <div class="bg-[var(--color-warm-bg-alt)] border-t border-[var(--color-gold)]/10 px-6 py-3 flex items-center justify-between">
              <span class="text-xs font-semibold text-navy/70 bg-[var(--color-gold)]/15 px-3 py-1 rounded-full">{form.badge}</span>
              <span class="inline-flex items-center text-sm text-[#2C5F8A] font-medium">
                Open form
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <!-- Printable forms link -->
      <div class="text-center mt-10">
        <a href="/forms/printable-forms.html" class="inline-flex items-center gap-2 text-[#2C5F8A] hover:text-[var(--color-gold-dark)] font-medium transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
          Prefer paper? View printable forms
        </a>
      </div>

      <!-- All forms hub link -->
      <div class="text-center mt-4">
        <a href="/forms/index.html" class="inline-flex items-center gap-2 text-grey-text hover:text-[var(--color-gold-dark)] text-sm transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          View all forms in one page
        </a>
      </div>
    </div>
  </section>

  <!-- ========== VIDEOS ========== -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">Video Resources</span>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mt-3 mb-4">Helpful Videos for Patients</h2>
        <p class="text-grey-text leading-relaxed">Watch these short videos to help you understand what to expect and get the most out of your chiropractic care.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-[var(--color-warm-bg)] rounded-2xl overflow-hidden border border-[var(--color-gold)]/15">
          <div class="aspect-video">
            <iframe
              src="https://www.youtube.com/embed/K8l9e0N1CTw"
              title="Initial Appointment Beginners Guide"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              class="w-full h-full"
            ></iframe>
          </div>
          <div class="p-5">
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy">Initial Appointment Beginners Guide</h3>
            <p class="text-grey-text text-sm mt-1">Not sure what to expect at your first visit? This video walks you through exactly what happens during your initial chiropractic appointment.</p>
          </div>
        </div>
        <div class="bg-[var(--color-warm-bg)] rounded-2xl overflow-hidden border border-[var(--color-gold)]/15">
          <div class="aspect-video">
            <iframe
              src="https://www.youtube.com/embed/-U_i9UnOPQs"
              title="How Often Should You See a Chiropractor?"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
              class="w-full h-full"
            ></iframe>
          </div>
          <div class="p-5">
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy">How Often Should You See a Chiropractor?</h3>
            <p class="text-grey-text text-sm mt-1">A common question from new patients. Learn how visit frequency is tailored to your individual needs and phase of care.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== BOOKING CTA ========== -->
  <section class="relative py-20 md:py-28 overflow-hidden">
    <img src="/images/clinic-adjustment-wide.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a1f35]/95 to-[#0a1f35]/85"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-semibold text-white mb-5">Ready to Book Your Visit?</h2>
      <p class="text-white/80 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">Complete your form above, then book your appointment online. We look forward to helping you feel your best.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[var(--color-gold)] hover:bg-[var(--color-gold-dark)] text-white px-10 py-4 rounded-lg text-lg font-medium transition-all duration-300 shadow-lg hover:-translate-y-0.5">
          Book Online Now
        </a>
        <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white px-10 py-4 rounded-lg text-lg font-medium transition-all duration-300 border border-white/15 whitespace-nowrap">
          Call {clinic.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
