---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic, practitioners, pricing } from '../data/clinic';
import { services } from '../data/services';
import { conditions } from '../data/conditions';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Banora Chiropractic — Chiropractor Tweed Heads South',
  description: 'Professional chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater. Over 30 years combined experience. Book online.',
  url: clinic.website,
};

const areas = ['Tweed Heads South', 'Tweed Heads', 'Banora Point', 'Coolangatta', 'Palm Beach', 'Currumbin', 'Elanora', 'Bilinga', 'Tugun', 'Kirra', 'Burleigh Heads', 'Terranora', 'Chinderah', 'Kingscliff'];
---

<BaseLayout
  title="Chiropractor Tweed Heads South | Banora Chiropractic"
  description="Professional chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater offer expert back pain, neck pain, and family chiropractic care. Over 30 years combined experience. Book online."
  schema={schema}
>

  <style>
    :root {
      --color-gold: #D4A853;
      --color-gold-light: #E8C97D;
      --color-gold-dark: #B88E3A;
      --color-warm-bg: #FFFBF3;
      --color-warm-bg-alt: #FFF8EB;
    }
    .glow-btn {
      background: linear-gradient(135deg, #DC2626, #B91C1C);
      border: 2px solid rgba(220, 38, 38, 0.5);
      box-shadow:
        0 0 15px rgba(220, 38, 38, 0.4),
        0 0 30px rgba(220, 38, 38, 0.2),
        0 0 60px rgba(220, 38, 38, 0.1);
      animation: glowPulse 2.5s ease-in-out infinite;
    }
    .glow-btn:hover {
      background: linear-gradient(135deg, #EF4444, #DC2626);
      box-shadow:
        0 0 20px rgba(220, 38, 38, 0.6),
        0 0 40px rgba(220, 38, 38, 0.3),
        0 0 80px rgba(220, 38, 38, 0.15);
    }
    @keyframes glowPulse {
      0%, 100% {
        box-shadow:
          0 0 15px rgba(220, 38, 38, 0.4),
          0 0 30px rgba(220, 38, 38, 0.2),
          0 0 60px rgba(220, 38, 38, 0.1);
      }
      50% {
        box-shadow:
          0 0 25px rgba(220, 38, 38, 0.6),
          0 0 50px rgba(220, 38, 38, 0.35),
          0 0 80px rgba(220, 38, 38, 0.15);
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .glow-btn { animation: none; }
    }
  </style>

  <!-- ========== HERO WITH ANIMATED BANNER SLIDER ========== -->
  <section class="relative h-[85vh] min-h-[600px] max-h-[900px] overflow-hidden">
    <!-- Sliding Images -->
    <div id="hero-slider" class="absolute inset-0">
      <div class="hero-slide absolute inset-0 opacity-100 transition-opacity duration-[1500ms] ease-in-out hero-overflow-clip">
        <img src="/images/clinic-neck-assessment.jpg" alt="Chiropractor performing a neck assessment at Banora Chiropractic" class="hero-ken-burns" />
      </div>
      <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-[1500ms] ease-in-out hero-overflow-clip">
        <img src="/images/hero-all-ages.jpg" alt="Happy couple representing chiropractic care for all ages" class="hero-ken-burns-reverse" />
      </div>
      <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-[1500ms] ease-in-out hero-overflow-clip">
        <img src="/images/clinic-spinal-adjustment.jpg" alt="Spinal adjustment at Banora Chiropractic clinic" class="hero-ken-burns" />
      </div>
      <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-[1500ms] ease-in-out hero-overflow-clip">
        <img src="/images/hero-sports.jpg" alt="Active person representing sports chiropractic care" class="hero-ken-burns" />
      </div>
      <div class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-[1500ms] ease-in-out hero-overflow-clip">
        <img src="/images/clinic-adjustment-wide.jpg" alt="Wide view of chiropractic adjustment at Banora Chiropractic" class="hero-ken-burns-reverse" />
      </div>
    </div>

    <!-- Gradient Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a1f35]/55 via-[#0a1f35]/30 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a1f35]/30 via-transparent to-transparent"></div>

    <!-- Hero Content -->
    <div class="relative h-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col justify-center">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-md text-white/90 text-sm px-5 py-2 rounded-full mb-8 border border-[var(--color-gold)]/30">
          <span class="w-2 h-2 bg-[var(--color-gold)] rounded-full animate-pulse"></span>
          Accepting new patients
        </div>

        <!-- Animated text that changes with slides -->
        <div id="hero-text-container" class="relative min-h-[200px] md:min-h-[180px]">
          <div class="hero-text-slide transition-all duration-700 ease-out" data-index="0">
            <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-white leading-[1.1] mb-5">
              Expert Chiropractic<br/>Care in <span class="text-[var(--color-gold)]">Tweed Heads South</span>
            </h1>
            <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-xl">Over 30 years of combined experience helping families move better and feel better.</p>
          </div>
          <div class="hero-text-slide absolute top-0 left-0 opacity-0 transition-all duration-700 ease-out" data-index="1">
            <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-white leading-[1.1] mb-5">
              Care for <span class="text-[var(--color-gold)]">Every Age</span><br/>& Every Stage
            </h1>
            <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-xl">From newborns to grandparents — gentle, personalised chiropractic care for your whole family.</p>
          </div>
          <div class="hero-text-slide absolute top-0 left-0 opacity-0 transition-all duration-700 ease-out" data-index="2">
            <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-white leading-[1.1] mb-5">
              Relief From<br/><span class="text-[var(--color-gold)]">Back & Neck Pain</span>
            </h1>
            <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-xl">Targeted care that aims to address the cause — not just the symptoms.</p>
          </div>
          <div class="hero-text-slide absolute top-0 left-0 opacity-0 transition-all duration-700 ease-out" data-index="3">
            <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-white leading-[1.1] mb-5">
              Get Back to<br/>Doing What <span class="text-[var(--color-gold)]">You Love</span>
            </h1>
            <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-xl">Sports chiropractic for active people — helping you recover, perform, and stay injury-free.</p>
          </div>
          <div class="hero-text-slide absolute top-0 left-0 opacity-0 transition-all duration-700 ease-out" data-index="4">
            <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-white leading-[1.1] mb-5">
              Gentle Support<br/>Through <span class="text-[var(--color-gold)]">Pregnancy</span>
            </h1>
            <p class="text-white/80 text-lg md:text-xl leading-relaxed max-w-xl">Safe, modified techniques to help you feel comfortable as your body changes.</p>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-[var(--color-gold)] hover:bg-[var(--color-gold-dark)] text-white px-8 py-4 rounded-lg text-lg font-medium transition-all duration-300 shadow-lg shadow-[#D4A853]/25 hover:shadow-[#B88E3A]/25 hover:-translate-y-0.5">
            Book Your Visit
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/symptom-checker" class="glow-btn inline-flex items-center justify-center text-white px-8 py-4 rounded-lg text-lg font-medium transition-all duration-300 hover:-translate-y-0.5">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Check Your Symptoms
          </a>
          <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white px-8 py-4 rounded-lg text-lg font-medium transition-all duration-300 border border-white/15">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {clinic.phone}
          </a>
        </div>
      </div>

      <!-- Slide Indicators -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3">
        {[0,1,2,3,4].map((i) => (
          <button class="slide-dot w-2.5 h-2.5 rounded-full transition-all duration-500 bg-white/30 hover:bg-white/60" data-slide={i} aria-label={`Go to slide ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== STATS BAR ========== -->
  <section class="bg-[#0f2d47] border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="group">
          <div class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-[var(--color-gold)] mb-1">30+</div>
          <div class="text-white/50 text-xs tracking-widest uppercase">Years Combined Experience</div>
        </div>
        <div class="group">
          <div class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-[var(--color-gold)] mb-1">2</div>
          <div class="text-white/50 text-xs tracking-widest uppercase">Expert Chiropractors</div>
        </div>
        <div class="group">
          <div class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-[var(--color-gold)] mb-1">6</div>
          <div class="text-white/50 text-xs tracking-widest uppercase">Days Open Per Week</div>
        </div>
        <div class="group">
          <div class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-[var(--color-gold)] mb-1">5</div>
          <div class="text-white/50 text-xs tracking-widest uppercase">Specialised Services</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TRUST BADGES ========== -->
  <section class="bg-[var(--color-warm-bg)] border-b border-[var(--color-gold)]/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-4 text-sm text-grey-text">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-[#2C5F8A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          AHPRA Registered
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-[#2C5F8A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          HICAPS On-Site
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-[#2C5F8A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Wheelchair Accessible
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-[#2C5F8A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Free On-Site Parking
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-[#2C5F8A]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Family Friendly
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SERVICES ========== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">Our Services</span>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mt-3 mb-4">How We Can Help You</h2>
        <p class="text-grey-text leading-relaxed">A range of chiropractic services tailored to your needs — from hands-on adjustments to specialised care for pregnancy, children, and sports.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, i) => (
          <a href={`/services/${service.slug}`} class="group relative bg-white rounded-2xl overflow-hidden border border-grey-mid/20 hover:border-[var(--color-gold)]/40 hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
            <div class="h-48 overflow-hidden">
              <img
                src={`/images/${i === 0 ? 'clinic-spinal-adjustment' : i === 1 ? 'hero-back-neck' : i === 2 ? 'hero-sports' : i === 3 ? 'hero-pregnancy' : 'hero-all-ages'}.jpg`}
                alt={service.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                width="500" height="300" loading="lazy"
              />
              <div class="absolute top-0 left-0 right-0 h-48 bg-gradient-to-t from-navy/60 to-transparent"></div>
            </div>
            <div class="p-6">
              <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-2 group-hover:text-[#2C5F8A] transition-colors">{service.title}</h3>
              <p class="text-grey-text text-sm leading-relaxed mb-4">{service.shortDescription}</p>
              <span class="inline-flex items-center text-sm text-[#2C5F8A] font-medium">
                Learn more
                <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CONDITIONS ========== -->
  <section class="py-20 md:py-28 bg-[var(--color-warm-bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">Common Conditions</span>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mt-3 mb-4">What Brings People to Us</h2>
        <p class="text-grey-text leading-relaxed">These are the most common reasons people walk through our door — and we may be able to help you too.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {conditions.map((condition) => (
          <a href={`/conditions/${condition.slug}`} class="group bg-white rounded-xl p-6 text-center border border-[var(--color-gold)]/15 hover:border-[var(--color-gold)]/40 hover:shadow-lg transition-all duration-500 hover:-translate-y-1">
            <div class="text-3xl mb-3">{condition.icon}</div>
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy group-hover:text-[#2C5F8A] transition-colors">{condition.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== WHAT TO EXPECT (with image) ========== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">Your First Visit</span>
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mt-3 mb-8">What to Expect</h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white font-semibold text-sm">1</div>
              <div>
                <h3 class="text-navy font-semibold">Book Online or Call</h3>
                <p class="text-grey-text text-sm mt-1">Pick a time that works — same-week appointments often available.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white font-semibold text-sm">2</div>
              <div>
                <h3 class="text-navy font-semibold">Your Assessment (45 min)</h3>
                <p class="text-grey-text text-sm mt-1">We chat about your health, do a thorough exam, and explain what we find.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white font-semibold text-sm">3</div>
              <div>
                <h3 class="text-navy font-semibold">Your First Treatment</h3>
                <p class="text-grey-text text-sm mt-1">Included in your initial visit — we get started right away.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-10 h-10 bg-[var(--color-gold)] rounded-full flex items-center justify-center shrink-0 text-white font-semibold text-sm">4</div>
              <div>
                <h3 class="text-navy font-semibold">Your Care Plan</h3>
                <p class="text-grey-text text-sm mt-1">Honest recommendations — no lock-in contracts, no pressure.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img src="/images/chiropractic-visit.jpg" alt="Chiropractor explaining spinal health to a patient at Banora Chiropractic" class="w-full h-auto" width="600" height="400" loading="lazy" />
          </div>
          <div class="absolute -bottom-4 -right-4 bg-[var(--color-gold)] text-white rounded-xl px-5 py-3 shadow-lg">
            <div class="text-sm font-medium">New patients welcome</div>
            <div class="text-xs text-white/70">Same-week appointments</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== TEAM ========== -->
  <section class="py-20 md:py-28 bg-[var(--color-warm-bg)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="text-sm text-[var(--color-gold)] font-medium uppercase tracking-[0.2em]">Your Chiropractors</span>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mt-3 mb-4">Meet the Team</h2>
        <p class="text-grey-text leading-relaxed">Two experienced practitioners with a shared commitment to helping you move and feel better.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {practitioners.map((doc) => (
          <div class="group bg-white rounded-2xl overflow-hidden border border-[var(--color-gold)]/15 hover:shadow-xl transition-all duration-500">
            <div class="aspect-[3/4] overflow-hidden bg-navy/5">
              <img src={`/images/${doc.slug}.jpg`} alt={`${doc.name}, chiropractor at Banora Chiropractic, Tweed Heads South`} class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700" width="400" height="533" loading="lazy" />
            </div>
            <div class="p-8">
              <h3 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy">{doc.name}</h3>
              <p class="text-[#2C5F8A] font-medium mt-1">{doc.qualifications}</p>
              <p class="text-grey-text text-sm mt-4 leading-relaxed">{doc.bio}</p>
              <div class="flex flex-wrap gap-2 mt-5">
                {doc.techniques.map((tech) => (
                  <span class="text-xs bg-[var(--color-warm-bg-alt)] text-navy px-3 py-1.5 rounded-full font-medium">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

