<script>
  // Hero slider with crossfade
  const slides = document.querySelectorAll('.hero-slide');
  const textSlides = document.querySelectorAll('.hero-text-slide');
  const dots = document.querySelectorAll('.slide-dot');
  let current = 0;
  let interval: ReturnType<typeof setInterval>;

  function goToSlide(index: number) {
    // Fade out current
    slides[current].classList.remove('opacity-100');
    slides[current].classList.add('opacity-0');
    textSlides[current].classList.remove('opacity-100');
    textSlides[current].classList.add('opacity-0');
    textSlides[current].style.position = 'absolute';
    dots[current].classList.remove('bg-white', 'w-8');
    dots[current].classList.add('bg-white/30', 'w-2.5');

    current = index;

    // Fade in new
    slides[current].classList.remove('opacity-0');
    slides[current].classList.add('opacity-100');
    textSlides[current].classList.remove('opacity-0');
    textSlides[current].classList.add('opacity-100');
    textSlides[current].style.position = 'relative';
    dots[current].classList.remove('bg-white/30', 'w-2.5');
    dots[current].classList.add('bg-white', 'w-8');
  }

  function nextSlide() {
    goToSlide((current + 1) % slides.length);
  }

  function startAutoplay() {
    interval = setInterval(nextSlide, 5000);
  }

  // Initialize
  dots[0].classList.remove('bg-white/30', 'w-2.5');
  dots[0].classList.add('bg-white', 'w-8');

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      clearInterval(interval);
      goToSlide(i);
      startAutoplay();
    });
  });

  startAutoplay();
</script>
