---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogPosts } from '../data/blog';
import { practitioners } from '../data/clinic';

const drafts = [...blogPosts]
  .filter(p => p.status === 'draft')
  .sort((a, b) => new Date(a.publishDate).getTime() - new Date(b.publishDate).getTime());

function getAuthor(slug: string) {
  return practitioners.find(p => p.slug === slug) || practitioners[0];
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-AU', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Draft Posts | Banora Chiropractic"
  description="Internal preview of draft blog posts."
  noindex={true}
>
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="bg-yellow-50 border border-yellow-200 rounded-lg px-6 py-4 mb-10 flex items-start gap-3">
        <span class="text-yellow-600 text-xl mt-0.5">⚠️</span>
        <div>
          <p class="font-semibold text-yellow-800">Draft preview — not visible to the public</p>
          <p class="text-yellow-700 text-sm mt-1">These posts are hidden from the live site and from Google. To publish one, open Claude Code and say <strong>"publish the [post name] post"</strong>.</p>
        </div>
      </div>

      <h1 class="font-[family-name:var(--font-display)] text-3xl font-semibold text-navy mb-2">Draft Blog Posts</h1>
      <p class="text-grey-text mb-10">{drafts.length} post{drafts.length !== 1 ? 's' : ''} waiting to be published</p>

      {drafts.length === 0 ? (
        <div class="text-center py-16 border border-grey-mid/20 rounded-xl">
          <p class="text-grey-text text-lg">No draft posts — all posts are published!</p>
        </div>
      ) : (
        <div class="space-y-8">
          {drafts.map((post) => {
            const author = getAuthor(post.author);
            return (
              <article class="border border-grey-mid/20 rounded-xl overflow-hidden">
                <div class="bg-yellow-50 border-b border-yellow-200 px-6 py-3 flex items-center justify-between">
                  <span class="text-yellow-700 text-sm font-medium">DRAFT — Scheduled for {formatDate(post.publishDate)}</span>
                  <span class="text-yellow-600 text-sm">To publish: say "publish the {post.title.split(':')[0].toLowerCase()} post" in Claude Code</span>
                </div>
                <div class="p-6 md:p-8">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="bg-blue-ghost text-mid-blue text-xs font-medium px-3 py-1 rounded-full">{post.category}</span>
                    <span class="text-grey-text text-sm">{post.readTime} min read</span>
                  </div>
                  <h2 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy mb-3">{post.title}</h2>
                  <p class="text-grey-text mb-6">{post.excerpt}</p>
                  <div class="prose prose-slate max-w-none text-sm border-t border-grey-mid/20 pt-6" set:html={post.content} />
                  <div class="flex items-center gap-3 mt-8 pt-6 border-t border-grey-mid/20">
                    <div>
                      <p class="text-sm font-medium text-navy">{author.name}</p>
                      <p class="text-xs text-grey-text">{author.credentials}</p>
                    </div>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
