---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic, practitioners, pricing } from '../data/clinic';
import { services } from '../data/services';
import { conditions } from '../data/conditions';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Banora Chiropractic — Chiropractor Tweed Heads South',
  description: 'Professional chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater. Over 30 years combined experience. Book online.',
  url: clinic.website,
};

const areas = ['Tweed Heads South', 'Tweed Heads', 'Banora Point', 'Coolangatta', 'Palm Beach', 'Currumbin', 'Elanora', 'Bilinga', 'Tugun', 'Kirra', 'Burleigh Heads', 'Terranora', 'Chinderah', 'Kingscliff'];

const serviceIcons: Record<string, string> = {
  'chiropractic-adjustments': '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342"/></svg>',
  'posture-correction': '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>',
  'sports-chiropractic': '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>',
  'pregnancy-chiropractic': '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>',
  'paediatric-chiropractic': '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/></svg>',
};

const whatToExpect = [
  { step: '1', title: 'Book Your Visit', description: 'Schedule online or give us a call. We will find a time that works for you.' },
  { step: '2', title: 'Your First Assessment', description: 'We will chat about your health history, do a thorough exam, and explain what we find.' },
  { step: '3', title: 'Your Care Plan', description: 'We will recommend a plan tailored to your needs — no pressure, no lock-in contracts.' },
  { step: '4', title: 'Feel the Difference', description: 'With regular care and guidance, many patients start to notice improvements in how they move and feel.' },
];
---

<BaseLayout
  title="Chiropractor Tweed Heads South | Banora Chiropractic"
  description="Warm, welcoming chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater help families with back pain, neck pain, and more. Over 30 years combined experience. Book online."
  schema={schema}
>

  <style>
    :root {
      --color-gold: #D4A853;
      --color-gold-light: #E8C97D;
      --color-gold-dark: #B88E3A;
      --color-warm-bg: #FFFBF3;
      --color-warm-bg-alt: #FFF8EB;
    }
  </style>

  <!-- ==================== HERO — Split layout: text left, image right ==================== -->
  <section class="bg-[var(--color-warm-bg)]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[560px] md:min-h-[620px]">
        <!-- Text side -->
        <div class="flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-16 lg:py-20">
          <div class="inline-flex items-center gap-2 text-sm font-medium mb-6" style="color: var(--color-gold-dark);">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Welcoming new patients in Tweed Heads South
          </div>
          <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-[3.4rem] font-semibold text-navy leading-[1.15] mb-6">
            Care That Feels Like <span style="color: var(--color-gold);">Family</span>
          </h1>
          <p class="text-grey-text text-lg leading-relaxed mb-8 max-w-lg">
            At Banora Chiropractic, you are more than a patient. Dr James and Dr Paul take the time to listen, understand, and create a care plan that genuinely fits your life.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center text-white px-8 py-4 rounded-2xl text-lg font-medium transition-colors hover:opacity-90" style="background-color: var(--color-gold);">
              Book Your Visit
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white text-navy px-8 py-4 rounded-2xl text-lg font-medium shadow-sm hover:shadow-md transition-shadow border border-grey-mid/20">
              <svg class="w-5 h-5 mr-2 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {clinic.phone}
            </a>
          </div>
          <!-- Trust indicators -->
          <div class="flex flex-wrap gap-4 mt-8 text-sm text-grey-text">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              AHPRA Registered
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              30+ Years Experience
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              HICAPS On-Site
            </span>
          </div>
        </div>
        <!-- Image side -->
        <div class="relative hidden lg:block">
          <img
            src="/images/hero-all-ages.jpg"
            alt="Family of all ages enjoying active, healthy lives with chiropractic care at Banora Chiropractic"
            class="absolute inset-0 w-full h-full object-cover"
            width="800"
            height="620"
            loading="eager"
          />
        </div>
        <!-- Mobile image (below text) -->
        <div class="lg:hidden">
          <img
            src="/images/hero-all-ages.jpg"
            alt="Family of all ages enjoying active, healthy lives with chiropractic care at Banora Chiropractic"
            class="w-full h-64 sm:h-80 object-cover"
            width="800"
            height="400"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SERVICES — Icon-forward rounded cards ==================== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold-dark);">What We Offer</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Care for Every Stage of Life</h2>
        <p class="text-grey-text leading-relaxed">Whether you are a busy parent, an active retiree, a weekend athlete, or expecting a baby — we have a service to help you feel your best.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a href={`/services/${service.slug}`} class="group bg-white rounded-2xl p-7 shadow-sm hover:shadow-lg border border-grey-mid/15 transition-all duration-300">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 text-white" style="background-color: var(--color-gold);">
              <Fragment set:html={serviceIcons[service.slug] || `<span class="text-2xl">${service.icon}</span>`} />
            </div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-2 group-hover:text-mid-blue transition-colors">{service.title}</h3>
            <p class="text-grey-text text-sm leading-relaxed mb-4">{service.shortDescription}</p>
            <span class="inline-flex items-center text-sm font-medium group-hover:gap-2 transition-all" style="color: var(--color-gold-dark);">
              Learn more
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== CONDITIONS ==================== -->
  <section class="py-20 md:py-28" style="background-color: var(--color-warm-bg);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold-dark);">How We Can Help</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Common Conditions We See</h2>
        <p class="text-grey-text leading-relaxed">You are not alone. These are some of the most common reasons people walk through our door, and we may be able to help you too.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {conditions.map((condition) => (
          <a href={`/conditions/${condition.slug}`} class="group flex items-start gap-4 bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all duration-300">
            <span class="text-3xl shrink-0 mt-0.5">{condition.icon}</span>
            <div>
              <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy group-hover:text-mid-blue transition-colors">{condition.title}</h3>
              <p class="text-grey-text text-sm mt-1.5 leading-relaxed">{condition.shortDescription}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== WHAT TO EXPECT — Numbered steps with image ==================== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold-dark);">Your Journey</p>
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-8">What to Expect at Your First Visit</h2>
          <div class="space-y-8">
            {whatToExpect.map((item) => (
              <div class="flex gap-5">
                <div class="shrink-0 w-11 h-11 rounded-full flex items-center justify-center text-white font-semibold text-lg" style="background-color: var(--color-gold);">
                  {item.step}
                </div>
                <div>
                  <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy">{item.title}</h3>
                  <p class="text-grey-text text-sm mt-1 leading-relaxed">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="relative">
          <img
            src="/images/chiropractic-visit.jpg"
            alt="Patient being welcomed and cared for during a chiropractic visit at Banora Chiropractic"
            class="rounded-2xl shadow-lg w-full object-cover aspect-[4/5]"
            width="600"
            height="750"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-lg p-5 hidden md:block" style="border-left: 4px solid var(--color-gold);">
            <p class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy">New patients welcome</p>
            <p class="text-grey-text text-sm mt-0.5">Same-week appointments available</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== TEAM — Circular photos, centred, with quote-like descriptions ==================== -->
  <section class="py-20 md:py-28" style="background-color: var(--color-warm-bg-alt);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold-dark);">Your Chiropractors</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Meet the People Behind Your Care</h2>
        <p class="text-grey-text leading-relaxed">Friendly, experienced, and genuinely passionate about helping you feel your best.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto">
        {practitioners.map((doc) => (
          <div class="text-center">
            <div class="w-36 h-36 rounded-full overflow-hidden mx-auto mb-6 shadow-lg" style="border: 4px solid var(--color-gold-light);">
              <img
                src={`/images/${doc.slug}.png`}
                alt={`${doc.name}, ${doc.role} at Banora Chiropractic`}
                class="w-full h-full object-cover"
                width="144"
                height="144"
                loading="lazy"
              />
            </div>
            <h3 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy">{doc.name}</h3>
            <p class="text-sm font-medium mt-1" style="color: var(--color-gold-dark);">{doc.qualifications}</p>
            <p class="text-grey-text text-sm mt-1">{doc.role}</p>
            <!-- Quote-style bio -->
            <div class="mt-5 relative">
              <svg class="w-8 h-8 mx-auto mb-2 opacity-20" style="color: var(--color-gold);" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/></svg>
              <p class="text-grey-text text-sm leading-relaxed italic max-w-sm mx-auto">{doc.bio}</p>
            </div>
            <div class="flex flex-wrap justify-center gap-2 mt-5">
              {doc.techniques.map((tech) => (
                <span class="text-xs px-3 py-1.5 rounded-full font-medium text-navy" style="background-color: var(--color-gold-light); opacity: 0.6;">{tech}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/about" class="inline-flex items-center font-medium hover:opacity-80 transition-opacity" style="color: var(--color-gold-dark);">
          Learn more about our team
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== PRICING — Feature cards with gold accent ==================== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold-dark);">Transparent Pricing</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Simple, Honest Fees</h2>
        <p class="text-grey-text leading-relaxed">No hidden costs, no surprises. We believe in being upfront about our fees so you can focus on feeling better.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <!-- New Patient -->
        <div class="bg-white rounded-2xl p-7 shadow-sm border border-grey-mid/15 text-center relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1.5" style="background-color: var(--color-gold);"></div>
          <p class="text-sm font-semibold uppercase tracking-wider mt-2 mb-3" style="color: var(--color-gold-dark);">New Patient</p>
          <p class="font-[family-name:var(--font-display)] text-5xl font-semibold text-navy">${pricing.newPatient.price}</p>
          <p class="text-grey-text text-sm mt-2">${pricing.newPatient.studentChild} students/children</p>
          <hr class="my-5 border-grey-mid/20" />
          <p class="text-grey-text text-sm leading-relaxed">Full assessment, thorough exam, and your first treatment — all in one visit.</p>
          <p class="text-grey-text text-xs mt-3">Approx. {pricing.newPatient.duration}</p>
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="mt-5 block w-full text-center py-3 rounded-xl text-white font-medium transition-opacity hover:opacity-90" style="background-color: var(--color-gold);">
            Book Now
          </a>
        </div>
        <!-- Regular -->
        <div class="bg-white rounded-2xl p-7 shadow-lg border-2 text-center relative overflow-hidden" style="border-color: var(--color-gold);">
          <div class="absolute top-0 left-0 right-0 h-1.5" style="background-color: var(--color-gold);"></div>
          <span class="absolute -top-0 right-4 text-xs text-white px-3 py-1 rounded-b-lg font-medium" style="background-color: var(--color-gold);">Most Popular</span>
          <p class="text-sm font-semibold uppercase tracking-wider mt-2 mb-3" style="color: var(--color-gold-dark);">Regular Adjustment</p>
          <p class="font-[family-name:var(--font-display)] text-5xl font-semibold text-navy">${pricing.regularAdjustment.price}</p>
          <p class="text-grey-text text-sm mt-2">${pricing.regularAdjustment.studentChild} students/children</p>
          <hr class="my-5 border-grey-mid/20" />
          <p class="text-grey-text text-sm leading-relaxed">Targeted adjustment and check-in to keep you moving and feeling well.</p>
          <p class="text-grey-text text-xs mt-3">Approx. {pricing.regularAdjustment.duration}</p>
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="mt-5 block w-full text-center py-3 rounded-xl text-white font-medium transition-opacity hover:opacity-90" style="background-color: var(--color-gold);">
            Book Now
          </a>
        </div>
        <!-- Baby -->
        <div class="bg-white rounded-2xl p-7 shadow-sm border border-grey-mid/15 text-center relative overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1.5" style="background-color: var(--color-gold);"></div>
          <p class="text-sm font-semibold uppercase tracking-wider mt-2 mb-3" style="color: var(--color-gold-dark);">Baby / Newborn</p>
          <p class="font-[family-name:var(--font-display)] text-5xl font-semibold text-navy">From ${pricing.babyNewborn.priceFrom}</p>
          <p class="text-grey-text text-sm mt-2">Initial visit ${pricing.babyNewborn.initial}</p>
          <hr class="my-5 border-grey-mid/20" />
          <p class="text-grey-text text-sm leading-relaxed">Gentle assessment and care for your little one, using the lightest of touches.</p>
          <p class="text-grey-text text-xs mt-3">{pricing.babyNewborn.duration}</p>
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="mt-5 block w-full text-center py-3 rounded-xl text-white font-medium transition-opacity hover:opacity-90" style="background-color: var(--color-gold);">
            Book Now
          </a>
        </div>
      </div>
      <p class="text-center text-grey-text text-sm mt-8">We accept {clinic.payment.join(', ')}. Health fund claims processed instantly with HICAPS.</p>
    </div>
  </section>

  <!-- ==================== CTA — Warm background ==================== -->
  <section class="py-20 md:py-28 relative overflow-hidden" style="background-color: var(--color-warm-bg-alt);">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-5">You Deserve to Feel Your Best</h2>
      <p class="text-grey-text text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
        Whether it is nagging back pain, a stiff neck, or simply wanting to stay healthy and active — we are here for you. Book your first visit and let us start the conversation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center text-white px-10 py-4 rounded-2xl text-lg font-medium transition-opacity hover:opacity-90" style="background-color: var(--color-gold);">
          Book Your Visit
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white text-navy px-10 py-4 rounded-2xl text-lg font-medium shadow-sm hover:shadow-md transition-shadow border border-grey-mid/20">
          Call {clinic.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== AREAS SERVED ==================== -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold-dark);">Serving the Tweed & Gold Coast</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Areas We Serve</h2>
        <p class="text-grey-text">Conveniently located for residents across the Tweed Heads and southern Gold Coast region.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {areas.map((area) => (
          <a href={`/areas/${area.toLowerCase().replace(/\s+/g, '-')}`} class="bg-white text-navy text-sm px-5 py-2.5 rounded-full border border-grey-mid/30 hover:shadow-sm font-medium transition-all" style="hover: border-color: var(--color-gold);">
            {area}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== LOCATION ==================== -->
  <section class="py-16 md:py-20" style="background-color: var(--color-warm-bg);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest mb-3" style="color: var(--color-gold-dark);">Find Us</p>
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Come and See Us</h2>
          <p class="text-grey-text leading-relaxed mb-6">We are easy to find on Greenway Drive in Tweed Heads South. Free parking right out front, ground level access, and a warm welcome waiting for you.</p>
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0" style="color: var(--color-gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="text-navy font-medium">{clinic.address.full}</p>
                <p class="text-grey-text text-sm mt-0.5">{clinic.landmark}</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0" style="color: var(--color-gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href={`tel:${clinic.phoneFull}`} class="text-navy font-medium hover:text-mid-blue transition-colors">{clinic.phone}</a>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 mt-0.5 shrink-0" style="color: var(--color-gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <div>
                <p class="text-navy font-medium">Open 6 days a week</p>
                <div class="text-grey-text text-sm mt-1 space-y-0.5">
                  {clinic.hours.filter(h => h.open !== 'Closed').map((h) => (
                    <p>{h.day}: {h.open} – {h.close}</p>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg aspect-video">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3523.8!2d153.5375!3d-28.1894!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b911a6d7e2c0001%3A0x95d26a12c609fa2b!2s2%2F44+Greenway+Dr%2C+Tweed+Heads+South+NSW+2486!5e0!3m2!1sen!2sau"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Banora Chiropractic location on Google Maps"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
