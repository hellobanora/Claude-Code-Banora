---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { clinic } from '../../data/clinic';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Dr James Shipway',
  honorificPrefix: 'Dr',
  jobTitle: 'Chiropractor',
  hasCredential: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Bachelor of Chiropractic Science',
      educationalLevel: 'Degree',
      recognizedBy: { '@type': 'CollegeOrUniversity', name: 'Macquarie University' },
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Master of Chiropractic',
      educationalLevel: 'Masters',
      recognizedBy: { '@type': 'CollegeOrUniversity', name: 'Macquarie University' },
    },
  ],
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Macquarie University' },
  worksFor: {
    '@type': 'Chiropractic',
    name: clinic.name,
    url: clinic.website,
    address: {
      '@type': 'PostalAddress',
      streetAddress: clinic.address.street,
      addressLocality: clinic.address.suburb,
      addressRegion: clinic.address.state,
      postalCode: clinic.address.postcode,
      addressCountry: 'AU',
    },
  },
  url: `${clinic.website}/team/dr-james-shipway`,
  image: `${clinic.website}/images/dr-james-shipway-v2.webp`,
};
---

<BaseLayout
  title="Dr James Shipway | Chiropractor Banora Point | Banora Chiropractic"
  description="Meet Dr James Shipway, chiropractor and co-founder of Banora Chiropractic in Tweed Heads South. B.Sc.Chiro & M.Chiro, Macquarie University 2011. Sports care, family chiropractic, and posture correction."
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-navy relative hero-overflow-clip">
    <div class="absolute inset-0">
      <img src="/images/clinic-neck-assessment.webp" srcset="/images/clinic-neck-assessment-600w.webp 600w, /images/clinic-neck-assessment.webp 816w" sizes="100vw" alt="" class="hero-slow-pan h-full opacity-15" aria-hidden="true" loading="lazy" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep/95 via-navy/90 to-navy-light/85"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <nav class="text-sm text-light-blue-soft/60 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/about" class="hover:text-white transition-colors">About</a>
        <span class="mx-2">/</span>
        <span class="text-white">Dr James Shipway</span>
      </nav>
      <p class="text-light-blue text-sm font-medium uppercase tracking-wider mb-3">Meet your chiropractor</p>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-white mb-4">Dr James Shipway</h1>
      <p class="text-light-blue-soft/90 text-lg max-w-2xl">B.Sc.Chiro & M.Chiro — Macquarie University, 2011 &nbsp;·&nbsp; Chiropractor & Co-founder</p>
    </div>
  </section>

  <!-- Bio -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">

        <!-- Photo -->
        <div class="lg:col-span-2">
          <div class="rounded-2xl overflow-hidden border border-blue-pale shadow-lg">
            <img
              src="/images/dr-james-shipway-v2.webp"
              srcset="/images/dr-james-shipway-v2-450w.webp 450w, /images/dr-james-shipway-v2.webp 900w"
              sizes="(max-width: 1024px) calc(100vw - 32px), 600px"
              alt="Dr James Shipway, Chiropractor at Banora Chiropractic, Tweed Heads South"
              class="w-full object-cover object-top"
              width="600"
              height="900"
              loading="eager"
            />
          </div>
          <!-- Qualifications card -->
          <div class="mt-6 bg-blue-ghost rounded-xl p-6 border border-blue-pale">
            <h2 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy mb-4">Qualifications & Training</h2>
            <ul class="space-y-3 text-sm text-grey-text">
              <li class="flex gap-3">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>Bachelor of Chiropractic Science (B.Sc.Chiro), Macquarie University</span>
              </li>
              <li class="flex gap-3">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>Master of Chiropractic (M.Chiro), Macquarie University — Graduated 2011</span>
              </li>
              <li class="flex gap-3">
                <svg class="w-4 h-4 mt-0.5 shrink-0 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span>Registered with AHPRA</span>
              </li>
            </ul>
            <h3 class="font-[family-name:var(--font-display)] text-base font-semibold text-navy mt-5 mb-3">Techniques</h3>
            <div class="flex flex-wrap gap-2">
              {['Diversified', 'Thompson', 'Soft Tissue Therapy', 'Arthrostim'].map((t) => (
                <span class="text-xs bg-white text-navy px-3 py-1.5 rounded-full font-medium border border-blue-pale">{t}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Bio text -->
        <div class="lg:col-span-3">
          <h2 class="font-[family-name:var(--font-display)] text-3xl font-semibold text-navy mb-6">About Dr James</h2>
          <div class="prose prose-lg max-w-none text-grey-text leading-relaxed space-y-5">
            <p>Dr James Shipway knows what it is like to be the patient. Growing up, he dealt with his share of growing pains and sporting knocks — the kind that often get dismissed as part of childhood. Chiropractic care made a genuine difference to how he felt, and that early experience stayed with him. It is part of why he chose this profession, and part of why he takes the time to really listen to the people who walk through the door.</p>
            <p>James graduated from Macquarie University in 2011 with a Bachelor of Chiropractic Science and a Master of Chiropractic. He joined Palm Beach Chiropractic in 2018, and in 2020 he and Dr Paul Cater opened Banora Chiropractic together — bringing a new clinic to the Tweed Heads South community.</p>
            <p>Sport has always been a big part of James's life. He played AFL, tennis, and golf at representative level, and that grounding in high-performance movement shapes how he approaches care for active patients. He is just as comfortable working with a weekend footballer nursing a hamstring as he is with a grandparent dealing with long-standing stiffness.</p>
            <p>James uses a range of techniques — including Diversified, Thompson, Soft Tissue Therapy, and Arthrostim — and he adapts his approach based on what he finds and what you are comfortable with. There is no one-size-fits-all at Banora Chiropractic, and James is meticulous about tailoring care to the individual.</p>
            <p>James works with patients managing both acute and chronic conditions. Whether you have just hurt yourself and need help now, or you have been living with something for years and are finally ready to address it — he meets you where you are. He has a particular interest in sciatica and nerve-related leg pain, headaches, and neck pain, conditions that can significantly affect quality of life and often respond well to chiropractic care.</p>
            <p>His approach is straightforward: find out what is going on, explain it clearly, and work through it together. No jargon, no pressure, no unnecessary visits.</p>
          </div>

          <!-- Special interests -->
          <div class="mt-10">
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-5">Areas of Special Interest</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex gap-4 items-start p-4 bg-light-grey rounded-xl">
                <div class="w-10 h-10 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                  <h4 class="font-medium text-navy text-sm">Sports Chiropractic</h4>
                  <p class="text-xs text-grey-text mt-1 leading-relaxed">Evidence-informed care for athletes — from grassroots sport to competitive performance.</p>
                </div>
              </div>
              <div class="flex gap-4 items-start p-4 bg-light-grey rounded-xl">
                <div class="w-10 h-10 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <h4 class="font-medium text-navy text-sm">Family Chiropractic</h4>
                  <p class="text-xs text-grey-text mt-1 leading-relaxed">Gentle, age-appropriate care for children, teens, and families — all under one roof.</p>
                </div>
              </div>
              <div class="flex gap-4 items-start p-4 bg-light-grey rounded-xl">
                <div class="w-10 h-10 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h4 class="font-medium text-navy text-sm">Posture Correction</h4>
                  <p class="text-xs text-grey-text mt-1 leading-relaxed">Addressing the postural patterns that cause pain and restrict movement over time.</p>
                </div>
              </div>
              <div class="flex gap-4 items-start p-4 bg-light-grey rounded-xl">
                <div class="w-10 h-10 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
                </div>
                <div>
                  <h4 class="font-medium text-navy text-sm">Acute & Chronic Conditions</h4>
                  <p class="text-xs text-grey-text mt-1 leading-relaxed">From sudden injuries to long-standing pain — tailoring care to where you are right now.</p>
                </div>
              </div>
              <div class="flex gap-4 items-start p-4 bg-light-grey rounded-xl">
                <div class="w-10 h-10 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                </div>
                <div>
                  <h4 class="font-medium text-navy text-sm">Sciatica & Nerve Pain</h4>
                  <p class="text-xs text-grey-text mt-1 leading-relaxed">Assessment and management of sciatica and radiating leg pain that can limit daily life.</p>
                </div>
              </div>
              <div class="flex gap-4 items-start p-4 bg-light-grey rounded-xl">
                <div class="w-10 h-10 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                </div>
                <div>
                  <h4 class="font-medium text-navy text-sm">Headaches & Neck Pain</h4>
                  <p class="text-xs text-grey-text mt-1 leading-relaxed">Identifying and addressing cervicogenic headaches and neck-related pain that affect day-to-day life.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Meet Dr Paul callout -->
  <section class="py-12 bg-light-grey border-y border-blue-pale">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center gap-6">
        <img
          src="/images/dr-paul-cater-v2.webp"
          alt="Dr Paul Cater"
          class="w-20 h-20 rounded-full object-cover object-top shrink-0 border-2 border-blue-pale"
          width="80"
          height="80"
          loading="lazy"
        />
        <div class="text-center sm:text-left">
          <p class="text-sm text-mid-blue font-medium uppercase tracking-wider mb-1">James's co-founder</p>
          <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy">Meet Dr Paul Cater</h3>
          <p class="text-grey-text text-sm mt-1">James and Paul opened Banora Chiropractic together in 2020. Between them, they cover a broad range of techniques and special interests.</p>
        </div>
        <a href="/team/dr-paul-cater" class="sm:ml-auto shrink-0 inline-flex items-center gap-2 text-mid-blue hover:text-navy font-medium text-sm transition-colors whitespace-nowrap">
          View Dr Paul
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Booking CTA -->
  <section class="py-16 md:py-20 bg-navy relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 right-10 w-72 h-72 bg-light-blue rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-white mb-4">Book a visit with Dr James</h2>
      <p class="text-light-blue-soft/90 text-lg mb-8">Ready to get started? Book your first appointment online — new patients welcome.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-mid-blue hover:bg-light-blue text-white px-8 py-4 rounded-lg text-lg font-medium transition-colors">
          Book Online
        </a>
        <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg text-lg font-medium transition-colors whitespace-nowrap">
          Call {clinic.phone}
        </a>
      </div>
      <p class="text-light-blue-soft/60 text-sm mt-6">{clinic.address.full}</p>
    </div>
  </section>
</BaseLayout>
