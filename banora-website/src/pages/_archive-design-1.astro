---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic, practitioners, pricing } from '../data/clinic';
import { services } from '../data/services';
import { conditions } from '../data/conditions';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Banora Chiropractic — Chiropractor Tweed Heads South',
  description: 'Professional chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater. Over 30 years combined experience. Book online.',
  url: clinic.website,
};

const areas = ['Tweed Heads South', 'Tweed Heads', 'Banora Point', 'Coolangatta', 'Palm Beach', 'Currumbin', 'Elanora', 'Bilinga', 'Tugun', 'Kirra', 'Burleigh Heads', 'Terranora', 'Chinderah', 'Kingscliff'];
---

<BaseLayout
  title="Chiropractor Tweed Heads South | Banora Chiropractic"
  description="Professional chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater offer expert back pain, neck pain, and family chiropractic care. Over 30 years combined experience. Book online."
  schema={schema}
>

  <!-- ==================== HERO — Full-width image with LEFT navy gradient ==================== -->
  <section class="relative bg-navy-deep min-h-[540px] md:min-h-[600px] flex items-center overflow-hidden">
    <img
      src="/images/hero-chiro-exam.webp"
      alt="Chiropractor performing a spinal examination at Banora Chiropractic in Tweed Heads South"
      class="absolute inset-0 w-full h-full object-cover"
      width="1600"
      height="700"
      loading="eager"
    />
    <!-- Left-aligned gradient: opaque on left, transparent on right -->
    <div class="absolute inset-0 bg-gradient-to-r from-navy-deep via-navy-deep/90 to-transparent"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 w-full">
      <div class="max-w-xl">
        <p class="text-light-blue text-sm font-semibold uppercase tracking-widest mb-4">Tweed Heads South Chiropractors</p>
        <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl lg:text-6xl font-semibold text-white leading-[1.15] mb-6">
          Expert Chiropractic Care You Can Trust
        </h1>
        <p class="text-light-blue-soft text-lg md:text-xl leading-relaxed mb-8">
          Dr James Shipway and Dr Paul Cater bring over 30 years of combined experience to help you move better, feel better, and live better.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-mid-blue hover:bg-light-blue text-white px-8 py-4 rounded-lg text-lg font-medium transition-colors">
            Book Your Visit
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center border-2 border-white/30 hover:border-white/60 text-white px-8 py-4 rounded-lg text-lg font-medium transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {clinic.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== TRUST BADGES — inline row ==================== -->
  <section class="bg-white border-b border-grey-mid/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-wrap justify-center gap-x-10 gap-y-3 text-sm text-navy font-medium">
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          AHPRA Registered
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          30+ Years Combined Experience
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          HICAPS On-Site
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          Wheelchair Accessible
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          Family Friendly
        </span>
      </div>
    </div>
  </section>

  <!-- ==================== SERVICES — Clean 3-column grid with bordered cards ==================== -->
  <section class="py-20 md:py-28 bg-light-grey">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-mid-blue text-sm font-semibold uppercase tracking-widest mb-3">Our Services</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Comprehensive Chiropractic Care</h2>
        <p class="text-grey-text leading-relaxed">From hands-on spinal adjustments to specialised care for pregnancy and children, we offer a full range of services tailored to your needs.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a href={`/services/${service.slug}`} class="group bg-white border border-grey-mid/30 rounded-lg p-7 hover:border-mid-blue/40 hover:shadow-md transition-all duration-300">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">{service.icon}</span>
              <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy group-hover:text-mid-blue transition-colors">{service.title}</h3>
            </div>
            <p class="text-grey-text text-sm leading-relaxed mb-5">{service.shortDescription}</p>
            <span class="inline-flex items-center text-sm text-mid-blue font-medium">
              Learn more
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== CONDITIONS — bordered list style ==================== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-mid-blue text-sm font-semibold uppercase tracking-widest mb-3">How We Can Help</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Conditions We Treat</h2>
        <p class="text-grey-text leading-relaxed">Dealing with pain or discomfort? These are some of the most common reasons people visit us, and we may be able to help you too.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {conditions.map((condition) => (
          <a href={`/conditions/${condition.slug}`} class="group flex items-center gap-4 bg-light-grey rounded-lg p-5 border border-grey-mid/20 hover:border-mid-blue/30 hover:shadow-sm transition-all duration-300">
            <span class="text-2xl shrink-0">{condition.icon}</span>
            <div>
              <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy group-hover:text-mid-blue transition-colors">{condition.title}</h3>
              <p class="text-grey-text text-sm mt-1 leading-relaxed">{condition.shortDescription}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TEAM — side-by-side large cards with blue-ghost bg ==================== -->
  <section class="py-20 md:py-28 bg-blue-ghost">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-mid-blue text-sm font-semibold uppercase tracking-widest mb-3">Your Chiropractors</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Meet the Team</h2>
        <p class="text-grey-text leading-relaxed">Two experienced chiropractors, one shared goal — helping you feel your best.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {practitioners.map((doc) => (
          <div class="bg-white rounded-lg border border-blue-pale/40 overflow-hidden shadow-sm">
            <div class="bg-blue-ghost p-8 flex justify-center">
              <img
                src={`/images/${doc.slug}.webp`}
                alt={`${doc.name}, ${doc.role} at Banora Chiropractic`}
                class="w-40 h-40 rounded-full object-cover border-4 border-white shadow-md"
                width="160"
                height="160"
                loading="lazy"
              />
            </div>
            <div class="p-8">
              <h3 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy">{doc.name}</h3>
              <p class="text-mid-blue text-sm font-medium mt-1">{doc.qualifications} — {doc.role}</p>
              <p class="text-grey-text text-sm mt-4 leading-relaxed">{doc.bio}</p>
              <div class="flex flex-wrap gap-2 mt-5">
                {doc.techniques.map((tech) => (
                  <span class="text-xs bg-blue-pale text-navy px-3 py-1 rounded-full font-medium">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/about" class="inline-flex items-center text-mid-blue hover:text-navy font-medium transition-colors">
          Learn more about our team
          <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== PRICING — Horizontal comparison table ==================== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-mid-blue text-sm font-semibold uppercase tracking-widest mb-3">Transparent Pricing</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Our Fees</h2>
        <p class="text-grey-text leading-relaxed">No hidden costs, no surprises. HICAPS available on-site for instant health fund claims.</p>
      </div>

      <!-- Desktop table -->
      <div class="hidden md:block max-w-4xl mx-auto">
        <div class="bg-light-grey rounded-lg overflow-hidden border border-grey-mid/30">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-navy text-white">
                <th class="px-6 py-4 font-medium text-sm uppercase tracking-wider">Visit Type</th>
                <th class="px-6 py-4 font-medium text-sm uppercase tracking-wider text-center">Standard Fee</th>
                <th class="px-6 py-4 font-medium text-sm uppercase tracking-wider text-center">Student / Child</th>
                <th class="px-6 py-4 font-medium text-sm uppercase tracking-wider text-center">Duration</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-grey-mid/20">
                <td class="px-6 py-5">
                  <p class="font-medium text-navy">New Patient Visit</p>
                  <p class="text-grey-text text-sm mt-0.5">Full assessment, exam, and first treatment</p>
                </td>
                <td class="px-6 py-5 text-center font-[family-name:var(--font-display)] text-2xl font-semibold text-navy">${pricing.newPatient.price}</td>
                <td class="px-6 py-5 text-center text-grey-text">${pricing.newPatient.studentChild}</td>
                <td class="px-6 py-5 text-center text-grey-text">{pricing.newPatient.duration}</td>
              </tr>
              <tr class="border-b border-grey-mid/20 bg-blue-ghost/30">
                <td class="px-6 py-5">
                  <div class="flex items-center gap-2">
                    <p class="font-medium text-navy">Regular Adjustment</p>
                    <span class="text-xs bg-mid-blue text-white px-2 py-0.5 rounded-full">Most Common</span>
                  </div>
                  <p class="text-grey-text text-sm mt-0.5">Targeted adjustment and check-in</p>
                </td>
                <td class="px-6 py-5 text-center font-[family-name:var(--font-display)] text-2xl font-semibold text-navy">${pricing.regularAdjustment.price}</td>
                <td class="px-6 py-5 text-center text-grey-text">${pricing.regularAdjustment.studentChild}</td>
                <td class="px-6 py-5 text-center text-grey-text">{pricing.regularAdjustment.duration}</td>
              </tr>
              <tr>
                <td class="px-6 py-5">
                  <p class="font-medium text-navy">Baby / Newborn</p>
                  <p class="text-grey-text text-sm mt-0.5">Gentle assessment for little ones</p>
                </td>
                <td class="px-6 py-5 text-center font-[family-name:var(--font-display)] text-2xl font-semibold text-navy">From ${pricing.babyNewborn.priceFrom}</td>
                <td class="px-6 py-5 text-center text-grey-text">Initial ${pricing.babyNewborn.initial}</td>
                <td class="px-6 py-5 text-center text-grey-text">{pricing.babyNewborn.duration}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Mobile cards (visible on small screens) -->
      <div class="md:hidden grid grid-cols-1 gap-4 max-w-sm mx-auto">
        <div class="bg-light-grey rounded-lg p-6 border border-grey-mid/30">
          <p class="text-mid-blue text-sm font-semibold uppercase tracking-wider mb-1">New Patient</p>
          <p class="font-[family-name:var(--font-display)] text-3xl font-semibold text-navy">${pricing.newPatient.price}</p>
          <p class="text-grey-text text-sm mt-1">${pricing.newPatient.studentChild} students/children</p>
          <p class="text-grey-text text-xs mt-2">{pricing.newPatient.duration} — Full assessment, exam, and first treatment</p>
        </div>
        <div class="bg-light-grey rounded-lg p-6 border-2 border-mid-blue relative">
          <span class="absolute -top-3 left-4 bg-mid-blue text-white text-xs px-3 py-1 rounded-full">Most Common</span>
          <p class="text-mid-blue text-sm font-semibold uppercase tracking-wider mb-1">Regular Adjustment</p>
          <p class="font-[family-name:var(--font-display)] text-3xl font-semibold text-navy">${pricing.regularAdjustment.price}</p>
          <p class="text-grey-text text-sm mt-1">${pricing.regularAdjustment.studentChild} students/children</p>
          <p class="text-grey-text text-xs mt-2">{pricing.regularAdjustment.duration} — Targeted adjustment and check-in</p>
        </div>
        <div class="bg-light-grey rounded-lg p-6 border border-grey-mid/30">
          <p class="text-mid-blue text-sm font-semibold uppercase tracking-wider mb-1">Baby / Newborn</p>
          <p class="font-[family-name:var(--font-display)] text-3xl font-semibold text-navy">From ${pricing.babyNewborn.priceFrom}</p>
          <p class="text-grey-text text-sm mt-1">Initial ${pricing.babyNewborn.initial}</p>
          <p class="text-grey-text text-xs mt-2">{pricing.babyNewborn.duration} — Gentle assessment for little ones</p>
        </div>
      </div>

      <div class="text-center mt-8">
        <p class="text-grey-text text-sm">We accept {clinic.payment.join(', ')}. Health fund claims processed instantly with HICAPS.</p>
      </div>
    </div>
  </section>

  <!-- ==================== CTA — Navy background, centred text ==================== -->
  <section class="py-20 md:py-28 bg-navy">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-white mb-5">Ready to Take the First Step?</h2>
      <p class="text-light-blue-soft text-lg leading-relaxed mb-10 max-w-2xl mx-auto">
        Whether you are in pain, recovering from an injury, or simply want to stay well — we are here to help. New patients are always welcome.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-mid-blue hover:bg-light-blue text-white px-10 py-4 rounded-lg text-lg font-medium transition-colors">
          Book Online Now
        </a>
        <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center border-2 border-white/30 hover:border-white/60 text-white px-10 py-4 rounded-lg text-lg font-medium transition-colors">
          Call {clinic.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== AREAS SERVED ==================== -->
  <section class="py-16 md:py-20 bg-light-grey">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="text-mid-blue text-sm font-semibold uppercase tracking-widest mb-3">Serving the Tweed & Gold Coast</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Areas We Serve</h2>
        <p class="text-grey-text">Conveniently located for residents across the Tweed Heads and southern Gold Coast region.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {areas.map((area) => (
          <a href={`/areas/${area.toLowerCase().replace(/\s+/g, '-')}`} class="bg-white text-navy text-sm px-5 py-2.5 rounded-lg border border-grey-mid/30 hover:border-mid-blue hover:text-mid-blue font-medium transition-colors">
            {area}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== LOCATION ==================== -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-mid-blue text-sm font-semibold uppercase tracking-widest mb-3">Find Us</p>
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Visit Our Clinic</h2>
          <p class="text-grey-text leading-relaxed mb-6">We are located on Greenway Drive in Tweed Heads South, between Reece Plumbing and Border Bikes. Free on-site parking, ground level, no steps.</p>
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="text-navy font-medium">{clinic.address.full}</p>
                <p class="text-grey-text text-sm mt-0.5">{clinic.landmark}</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href={`tel:${clinic.phoneFull}`} class="text-navy font-medium hover:text-mid-blue transition-colors">{clinic.phone}</a>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <div>
                <p class="text-navy font-medium">Open 6 days a week</p>
                <div class="text-grey-text text-sm mt-1 space-y-0.5">
                  {clinic.hours.filter(h => h.open !== 'Closed').map((h) => (
                    <p>{h.day}: {h.open} – {h.close}</p>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-light-grey rounded-lg overflow-hidden aspect-video border border-grey-mid/20">
          <iframe
