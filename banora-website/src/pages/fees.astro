---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic, pricing } from '../data/clinic';

const feesFaqs = [
  {
    question: 'Do I need a referral to see a chiropractor?',
    answer: 'No. You can book a chiropractic appointment directly without a GP referral. A referral is only needed if you are claiming through Medicare (a Chronic Disease Management plan), DVA, WorkCover, or a CTP claim.',
  },
  {
    question: 'How do private health fund rebates work?',
    answer: 'We have HICAPS terminals on site, so your private health rebate is processed instantly when you pay. You only cover the gap on the day — there is no paperwork or waiting for a refund. The exact rebate depends on your fund and level of extras cover.',
  },
  {
    question: 'Can I claim chiropractic on Medicare?',
    answer: 'Some patients qualify for Medicare-rebated visits under a Chronic Disease Management (CDM) plan, formerly known as an EPC plan. Your GP decides if you are eligible and how many visits you receive (up to five per calendar year). Bring your referral and Medicare card to your appointment.',
  },
  {
    question: 'Is there a fee for cancelling or rescheduling?',
    answer: 'We understand that plans change. We simply ask that you give us as much notice as possible — ideally at least 24 hours — so we can offer your spot to someone else who needs it. You can reschedule online or by calling the clinic.',
  },
  {
    question: 'Do you offer concession pricing?',
    answer: `Yes. We offer reduced fees for students and children — $${pricing.newPatient.studentChild} for a new patient consult and $${pricing.regularAdjustment.studentChild} for a regular adjustment. Gentle care for babies and newborns starts from $${pricing.babyNewborn.priceFrom}.`,
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: clinic.website },
        { '@type': 'ListItem', position: 2, name: 'Fees', item: `${clinic.website}/fees` },
      ],
    },
    {
      '@type': 'WebPage',
      name: 'Chiropractic Prices | Banora Chiropractic',
      url: `${clinic.website}/fees`,
      description: 'Affordable and accessible chiropractic care. View our chiropractic fees and prices at Banora Chiropractic, Tweed Heads South.',
    },
    {
      '@type': 'FAQPage',
      mainEntity: feesFaqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: { '@type': 'Answer', text: faq.answer },
      })),
    },
  ],
};
---

<BaseLayout
  title="Chiropractic Prices | Affordable Chiropractic Fees | Banora Chiropractic"
  description="Affordable and accessible chiropractic care. View our chiropractic fees and prices. Located at Banora Point / Tweed Heads South NSW. Book online today."
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-navy relative hero-overflow-clip">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep/95 via-navy/90 to-navy-light/85"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <nav class="text-sm text-light-blue-soft/60 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white">Fees</span>
      </nav>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-white mb-4">Chiropractic Fees</h1>
      <p class="text-light-blue-soft/80 text-lg max-w-2xl">
        We believe quality chiropractic care should be accessible. Our fees are straightforward — no surprises, no lock-in plans.
      </p>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-12">
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Our Prices</h2>
        <p class="text-grey-text text-lg max-w-xl mx-auto">
          All consultations are with an AHPRA-registered chiropractor. Health fund rebates apply via HICAPS on the spot.
        </p>
      </div>

      <!-- Pricing Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mb-16 max-w-3xl mx-auto">

        <!-- New Patient -->
        <div class="bg-white rounded-xl border-2 border-mid-blue shadow-sm overflow-hidden">
          <div class="bg-mid-blue px-6 py-5">
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-white">New Patient Consult</h3>
            <p class="text-light-blue-soft/80 text-sm mt-1">{pricing.newPatient.duration}</p>
          </div>
          <div class="px-6 py-6">
            <div class="mb-4 text-center">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-4xl font-bold text-navy">${pricing.newPatient.price}</span>
              </div>
              <p class="text-grey-text text-sm mt-1">Standard fee</p>
            </div>
            <div class="border-t border-grey-mid/20 pt-4 text-center">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-2xl font-semibold text-navy">${pricing.newPatient.studentChild}</span>
              </div>
              <p class="text-grey-text text-sm mt-1">Student / child concession</p>
            </div>
            <ul class="mt-5 space-y-2 text-sm text-grey-text">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Full health history & assessment
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Postural & spinal examination
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Personalised care plan
              </li>
            </ul>
          </div>
        </div>

        <!-- Regular Adjustment -->
        <div class="bg-white rounded-xl border border-grey-mid/20 shadow-sm overflow-hidden">
          <div class="bg-navy px-6 py-5">
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-white">Regular Adjustment</h3>
            <p class="text-light-blue-soft/80 text-sm mt-1">{pricing.regularAdjustment.duration}</p>
          </div>
          <div class="px-6 py-6">
            <div class="mb-4 text-center">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-4xl font-bold text-navy">${pricing.regularAdjustment.price}</span>
              </div>
              <p class="text-grey-text text-sm mt-1">Standard fee</p>
            </div>
            <div class="border-t border-grey-mid/20 pt-4 text-center">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-2xl font-semibold text-navy">${pricing.regularAdjustment.studentChild}</span>
              </div>
              <p class="text-grey-text text-sm mt-1">Student / child concession</p>
            </div>
            <ul class="mt-5 space-y-2 text-sm text-grey-text">
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Targeted spinal adjustment
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Progress check-in
              </li>
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Ongoing care advice
              </li>
            </ul>
          </div>
        </div>

      </div>

      <!-- Health Funds & Extras -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

        <!-- Health Funds -->
        <div class="bg-light-grey rounded-xl p-6 md:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-mid-blue/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy">Private Health Funds</h3>
          </div>
          <p class="text-grey-text text-sm leading-relaxed mb-4">
            We have HICAPS on site, so you can claim your private health fund rebate instantly at the time of your visit. You only pay the gap — no paperwork, no waiting.
          </p>
          <p class="text-grey-text text-sm leading-relaxed">
            Most major health funds cover chiropractic care under extras. Check your policy for your specific rebate entitlements.
          </p>
        </div>

        <!-- DVA / EPC / WorkCover -->
        <div class="bg-light-grey rounded-xl p-6 md:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-mid-blue/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy">DVA, Medicare, WorkCover & CTP</h3>
          </div>
          <ul class="space-y-3 text-sm text-grey-text">
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span><strong class="text-navy">DVA:</strong> We welcome Department of Veterans' Affairs patients. With a valid referral, eligible veterans are bulk-billed with no out-of-pocket cost — just bring your DVA card and referral.</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span><strong class="text-navy">Medicare (EPC / CDM):</strong> If your GP has placed you on a Chronic Disease Management plan (formerly EPC), you may be eligible for up to five Medicare-rebated visits per calendar year. Bring your referral and Medicare card.</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span><strong class="text-navy">WorkCover:</strong> We treat work-related injuries under WorkCover. Please contact us with your claim number and case manager details before your first visit so we can confirm approval.</span>
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-mid-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span><strong class="text-navy">Motor accident (CTP):</strong> If you have been injured in a motor vehicle accident, we can treat you under a CTP claim. Get in touch with your claim details and we will help you understand the process.</span>
            </li>
          </ul>
        </div>

      </div>

      <!-- Payment Methods & Cancellations -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mt-6 md:mt-8">

        <!-- Payment Methods -->
        <div class="bg-light-grey rounded-xl p-6 md:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-mid-blue/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
            </div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy">Payment Methods</h3>
          </div>
          <p class="text-grey-text text-sm leading-relaxed mb-4">
            Payment is made at the time of your visit. We accept EFTPOS and all major cards, with HICAPS terminals on site for instant private health fund claims.
          </p>
          <div class="flex flex-wrap gap-2">
            {clinic.payment.map((method) => (
              <span class="text-xs bg-white text-navy px-3 py-1.5 rounded-full border border-grey-mid/20 font-medium">{method}</span>
            ))}
          </div>
        </div>

        <!-- Cancellations -->
        <div class="bg-light-grey rounded-xl p-6 md:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 bg-mid-blue/10 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy">Changes & Cancellations</h3>
          </div>
          <p class="text-grey-text text-sm leading-relaxed">
            Life happens — if you need to reschedule or cancel, we simply ask for as much notice as you can give, ideally at least 24 hours, so we can offer the time to another patient. You can change your appointment online or call us on <a href={`tel:${clinic.phoneFull}`} class="text-mid-blue hover:text-navy underline transition-colors">{clinic.phone}</a>.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Fees FAQ -->
  <section class="py-16 md:py-24 bg-light-grey">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-[family-name:var(--font-display)] text-2xl md:text-3xl font-semibold text-navy mb-8 text-center">Common Questions About Fees</h2>
      <div class="space-y-4">
        {feesFaqs.map((faq) => (
          <div class="bg-white rounded-xl border border-grey-mid/20 overflow-hidden">
            <button class="faq-toggle w-full flex items-center justify-between p-5 text-left" aria-expanded="false">
              <span class="font-medium text-navy pr-4">{faq.question}</span>
              <svg class="w-5 h-5 text-grey-text shrink-0 transition-transform duration-200 faq-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer hidden px-5 pb-5">
              <p class="text-grey-text leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-navy py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-white mb-4">
        Ready to book your first visit?
      </h2>
      <p class="text-light-blue-soft/80 text-lg mb-8 max-w-xl mx-auto">
        Book online in minutes or give us a call — we are always happy to answer any questions about fees or what to expect.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <button class="open-booking-modal bg-mid-blue hover:bg-light-blue text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors shadow-md">
          Book Online
        </button>
        <a href={`tel:${clinic.phoneFull}`} class="flex items-center gap-2 text-white hover:text-light-blue-soft transition-colors font-medium">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {clinic.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-toggle').forEach((button) => {
    button.addEventListener('click', () => {
      const answer = button.nextElementSibling;
      const chevron = button.querySelector('.faq-chevron');
      const isOpen = !answer?.classList.contains('hidden');

      document.querySelectorAll('.faq-answer').forEach(a => a.classList.add('hidden'));
      document.querySelectorAll('.faq-chevron').forEach(c => c.classList.remove('rotate-180'));
      document.querySelectorAll('.faq-toggle').forEach(b => b.setAttribute('aria-expanded', 'false'));

      if (!isOpen) {
        answer?.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
        button.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
