---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic } from '../data/clinic';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Banora Chiropractic',
  url: `${clinic.website}/contact`,
};
---

<BaseLayout
  title="Contact Us | Banora Chiropractic | Tweed Heads South"
  description="Contact Banora Chiropractic at 2/44 Greenway Drive, Tweed Heads South. Call (07) 5599 2322 or book online. Free parking, wheelchair accessible."
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-navy relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep via-navy to-navy-light opacity-95"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <nav class="text-sm text-light-blue-soft/60 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white">Contact</span>
      </nav>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-white mb-4">Get in Touch</h1>
      <p class="text-light-blue-soft/90 text-lg max-w-2xl">We would love to hear from you. Whether you have a question, want to book an appointment, or just need directions — we are here to help.</p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy mb-6">Send Us a Message</h2>
          <form action={clinic.formspreeEndpoint} method="POST" class="space-y-5">
            <!-- Honeypot -->
            <input type="text" name="_gotcha" style="display:none" />

            <div>
              <label for="name" class="block text-sm font-medium text-navy mb-1.5">Your Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-lg border border-grey-mid/40 focus:border-mid-blue focus:ring-2 focus:ring-mid-blue/20 outline-none transition-colors text-dark-text" placeholder="e.g. Sarah Johnson" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-navy mb-1.5">Email Address</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-grey-mid/40 focus:border-mid-blue focus:ring-2 focus:ring-mid-blue/20 outline-none transition-colors text-dark-text" placeholder="you@example.com" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-navy mb-1.5">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-lg border border-grey-mid/40 focus:border-mid-blue focus:ring-2 focus:ring-mid-blue/20 outline-none transition-colors text-dark-text" placeholder="04XX XXX XXX" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-navy mb-1.5">Your Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 rounded-lg border border-grey-mid/40 focus:border-mid-blue focus:ring-2 focus:ring-mid-blue/20 outline-none transition-colors text-dark-text resize-y" placeholder="How can we help you?"></textarea>
            </div>
            <button type="submit" class="w-full bg-mid-blue hover:bg-navy text-white px-6 py-3.5 rounded-lg font-medium transition-colors duration-200">
              Send Message
            </button>
            <p class="text-xs text-grey-text">We aim to respond within 1 business day. For urgent enquiries, please call us directly.</p>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy mb-6">Clinic Details</h2>
            <div class="space-y-5">
              <div class="flex gap-4 items-start">
                <div class="w-11 h-11 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <h3 class="text-navy font-medium">Address</h3>
                  <p class="text-grey-text text-sm mt-0.5">{clinic.address.full}</p>
                  <p class="text-grey-text text-xs mt-0.5">{clinic.landmark}</p>
                </div>
              </div>
              <div class="flex gap-4 items-start">
                <div class="w-11 h-11 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <h3 class="text-navy font-medium">Phone</h3>
                  <a href={`tel:${clinic.phoneFull}`} class="text-mid-blue font-medium hover:text-navy transition-colors">{clinic.phone}</a>
                </div>
              </div>
              <div class="flex gap-4 items-start">
                <div class="w-11 h-11 bg-blue-ghost rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h3 class="text-navy font-medium">Book Online</h3>
                  <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="text-mid-blue font-medium hover:text-navy transition-colors">Book your appointment</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Opening Hours -->
          <div class="bg-blue-ghost/50 rounded-xl p-6 border border-blue-pale/30">
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy mb-4">Opening Hours</h3>
            <div class="space-y-2">
              {clinic.hours.map((h) => (
                <div class="flex justify-between text-sm">
                  <span class="text-navy font-medium">{h.day}</span>
                  <span class={h.open === 'Closed' ? 'text-grey-text' : 'text-grey-text'}>{h.open === 'Closed' ? 'Closed' : `${h.open} – ${h.close}`}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Parking & Access -->
          <div class="bg-light-grey rounded-xl p-6">
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy mb-3">Getting Here</h3>
            <ul class="space-y-2 text-sm text-grey-text">
              <li class="flex gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Free on-site parking
              </li>
              <li class="flex gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Ground level — no steps
              </li>
              <li class="flex gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Wheelchair accessible
              </li>
              <li class="flex gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Between Reece Plumbing and Border Bikes
              </li>
            </ul>
          </div>

          <!-- Payment Methods -->
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy mb-3">Payment Options</h3>
            <div class="flex flex-wrap gap-2">
              {clinic.payment.map((method) => (
                <span class="text-sm bg-blue-ghost text-navy px-3 py-1.5 rounded-full">{method}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="bg-light-grey">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy mb-6 text-center">Find Us on the Map</h2>
      <div class="rounded-xl overflow-hidden aspect-[16/9] md:aspect-[21/9]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3523.8!2d153.5375!3d-28.1894!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b911a6d7e2c0001%3A0x95d26a12c609fa2b!2s2%2F44+Greenway+Dr%2C+Tweed+Heads+South+NSW+2486!5e0!3m2!1sen!2sau"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Banora Chiropractic location"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>
