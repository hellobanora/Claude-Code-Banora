---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic, practitioners, pricing } from '../data/clinic';
import { services } from '../data/services';
import { conditions } from '../data/conditions';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Banora Chiropractic — Chiropractor Tweed Heads South',
  description: 'Professional chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater. Over 30 years combined experience. Book online.',
  url: clinic.website,
};

const areas = ['Tweed Heads South', 'Tweed Heads', 'Banora Point', 'Coolangatta', 'Palm Beach', 'Currumbin', 'Elanora', 'Bilinga', 'Tugun', 'Kirra', 'Burleigh Heads', 'Terranora', 'Chinderah', 'Kingscliff'];

const stats = [
  { number: '30+', label: 'Years Combined Experience' },
  { number: '5', label: 'Services Offered' },
  { number: '2', label: 'Expert Chiropractors' },
  { number: '6', label: 'Days Open Per Week' },
];

const serviceImages: Record<string, string> = {
  'chiropractic-adjustments': '/images/hero-chiro-exam.jpg',
  'posture-correction': '/images/hero-back-neck.jpg',
  'sports-chiropractic': '/images/hero-sports.jpg',
  'pregnancy-chiropractic': '/images/hero-pregnancy.jpg',
  'paediatric-chiropractic': '/images/hero-all-ages.jpg',
};
---

<BaseLayout
  title="Chiropractor Tweed Heads South | Banora Chiropractic"
  description="Modern chiropractic care in Tweed Heads South. Dr James Shipway and Dr Paul Cater deliver expert back pain, neck pain, sports and family chiropractic care. Over 30 years combined experience. Book online."
  schema={schema}
>

  <!-- ==================== HERO — Full-screen with dark gradient ==================== -->
  <section class="relative min-h-screen flex items-center bg-navy-deep overflow-hidden">
    <img
      src="/images/hero-sports.jpg"
      alt="Active lifestyle supported by sports chiropractic care at Banora Chiropractic"
      class="absolute inset-0 w-full h-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-deep via-navy-deep/80 to-navy-deep/40"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-deep/60 to-transparent"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 w-full">
      <div class="max-w-3xl">
        <p class="text-light-blue text-sm font-bold uppercase tracking-[0.2em] mb-6">Tweed Heads South</p>
        <h1 class="font-[family-name:var(--font-display)] text-5xl md:text-6xl lg:text-7xl font-semibold text-white leading-[1.05] mb-6">
          Move Better.<br />
          <span class="text-light-blue">Feel Better.</span><br />
          Live Better.
        </h1>
        <p class="text-light-blue-soft text-xl leading-relaxed mb-10 max-w-xl">
          Two expert chiropractors. Over 30 years of combined experience. One mission — helping you get back to doing what you love.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-light-blue hover:bg-light-blue-soft text-navy-deep px-10 py-5 rounded-lg text-lg font-semibold transition-colors">
            Book Your Visit
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white px-10 py-5 rounded-lg text-lg font-medium transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {clinic.phone}
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/50 animate-bounce">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>

  <!-- ==================== SECONDARY HERO — Split with back/neck image ==================== -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <div class="flex flex-col justify-center px-6 sm:px-10 lg:px-16 py-16 lg:py-24">
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy leading-tight mb-5">
            Expert Care for Pain, Performance, and Prevention
          </h2>
          <p class="text-grey-text text-lg leading-relaxed mb-6">
            Whether you are struggling with chronic back pain, recovering from a sports injury, or looking after your family's spinal health — Dr James Shipway and Dr Paul Cater have the experience and techniques to help.
          </p>
          <a href="/about" class="inline-flex items-center text-light-blue font-semibold hover:text-mid-blue transition-colors">
            Meet your chiropractors
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>
        <div class="relative min-h-[300px] lg:min-h-[400px]">
          <img
            src="/images/hero-back-neck.jpg"
            alt="Chiropractic care for back and neck pain at Banora Chiropractic"
            class="absolute inset-0 w-full h-full object-cover"
            width="800"
            height="500"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== STATS BAR — Large numbers in a prominent strip ==================== -->
  <section class="bg-navy-deep">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {stats.map((stat) => (
          <div>
            <p class="font-[family-name:var(--font-display)] text-5xl md:text-6xl font-semibold text-light-blue leading-none">{stat.number}</p>
            <p class="text-light-blue-soft/70 text-sm mt-2 uppercase tracking-wider font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== SERVICES — Horizontal cards, alternating sides ==================== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="text-light-blue text-sm font-bold uppercase tracking-[0.2em] mb-3">Our Services</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-semibold text-navy leading-tight">Comprehensive Chiropractic Care</h2>
      </div>
      <div class="space-y-8">
        {services.map((service, i) => (
          <a href={`/services/${service.slug}`} class="group grid grid-cols-1 md:grid-cols-2 gap-0 bg-light-grey rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300">
            <div class={`relative min-h-[220px] md:min-h-[280px] ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <img
                src={serviceImages[service.slug] || '/images/chiropractic-visit.jpg'}
                alt={`${service.title} at Banora Chiropractic in Tweed Heads South`}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                width="700"
                height="400"
                loading="lazy"
              />
            </div>
            <div class={`flex flex-col justify-center p-8 md:p-10 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
              <span class="text-3xl mb-3">{service.icon}</span>
              <h3 class="font-[family-name:var(--font-display)] text-2xl md:text-3xl font-semibold text-navy mb-3 group-hover:text-light-blue transition-colors leading-tight">{service.title}</h3>
              <p class="text-grey-text leading-relaxed mb-5">{service.shortDescription}</p>
              <span class="inline-flex items-center text-light-blue font-semibold text-sm">
                Learn more
                <svg class="w-4 h-4 ml-2 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== CONDITIONS — Grid of clickable tags/badges ==================== -->
  <section class="py-20 md:py-28 bg-navy-deep">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-light-blue text-sm font-bold uppercase tracking-[0.2em] mb-3">How We Help</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-semibold text-white leading-tight mb-4">Conditions We Work With</h2>
        <p class="text-light-blue-soft/70 leading-relaxed">Click any condition below to learn more about how chiropractic care may help.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
        {conditions.map((condition) => (
          <a href={`/conditions/${condition.slug}`} class="group flex items-center gap-4 bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl px-6 py-5 hover:bg-light-blue/10 hover:border-light-blue/30 transition-all duration-300">
            <span class="text-3xl shrink-0">{condition.icon}</span>
            <div>
              <h3 class="text-white font-semibold group-hover:text-light-blue transition-colors">{condition.title}</h3>
              <p class="text-light-blue-soft/60 text-sm mt-0.5 leading-relaxed">{condition.shortDescription}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TEAM — Dark background, large photos, navy cards ==================== -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-light-blue text-sm font-bold uppercase tracking-[0.2em] mb-3">Your Chiropractors</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-semibold text-navy leading-tight mb-4">Meet the Team</h2>
        <p class="text-grey-text leading-relaxed">Two experienced practitioners with a shared commitment to helping you move better and feel better.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {practitioners.map((doc) => (
          <div class="bg-navy-deep rounded-xl overflow-hidden shadow-xl">
            <div class="relative aspect-[4/3] bg-navy">
              <img
                src={`/images/${doc.slug}.png`}
                alt={`${doc.name}, ${doc.role} at Banora Chiropractic`}
                class="w-full h-full object-cover object-top"
                width="500"
                height="375"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-deep via-transparent to-transparent"></div>
            </div>
            <div class="p-8 -mt-12 relative z-10">
              <h3 class="font-[family-name:var(--font-display)] text-2xl md:text-3xl font-semibold text-white">{doc.name}</h3>
              <p class="text-light-blue text-sm font-medium mt-1">{doc.qualifications} — {doc.role}</p>
              <p class="text-light-blue-soft/70 text-sm mt-4 leading-relaxed">{doc.bio}</p>
              <div class="flex flex-wrap gap-2 mt-5">
                {doc.techniques.map((tech) => (
                  <span class="text-xs bg-light-blue/20 text-light-blue px-3 py-1.5 rounded-full font-medium">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/about" class="inline-flex items-center text-light-blue font-semibold hover:text-mid-blue transition-colors">
          Learn more about our team
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== PRICING — Bold with dark/light contrast ==================== -->
  <section class="py-20 md:py-28 bg-light-grey">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <p class="text-light-blue text-sm font-bold uppercase tracking-[0.2em] mb-3">Transparent Pricing</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl lg:text-5xl font-semibold text-navy leading-tight mb-4">Our Fees</h2>
        <p class="text-grey-text leading-relaxed">Straightforward pricing with no hidden costs. HICAPS on-site for instant claims.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <!-- New Patient -->
        <div class="bg-white rounded-xl p-8 text-center shadow-sm hover:shadow-lg transition-shadow">
          <p class="text-light-blue text-sm font-bold uppercase tracking-[0.15em] mb-4">New Patient</p>
          <p class="font-[family-name:var(--font-display)] text-6xl font-semibold text-navy leading-none">${pricing.newPatient.price}</p>
          <p class="text-grey-text text-sm mt-3">${pricing.newPatient.studentChild} students/children</p>
          <hr class="my-6 border-grey-mid/20" />
          <p class="text-grey-text text-sm leading-relaxed">Full assessment, exam, and first treatment</p>
          <p class="text-grey-text text-xs mt-2">Approx. {pricing.newPatient.duration}</p>
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="mt-6 block w-full text-center py-3.5 rounded-lg bg-navy-deep hover:bg-navy text-white font-medium transition-colors">
            Book Now
          </a>
        </div>
        <!-- Regular — Featured -->
        <div class="bg-navy-deep rounded-xl p-8 text-center shadow-xl relative md:-mt-4 md:mb-[-1rem]">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-light-blue text-navy-deep text-xs px-4 py-1 rounded-full font-bold uppercase tracking-wider">Most Common</span>
          <p class="text-light-blue text-sm font-bold uppercase tracking-[0.15em] mb-4 mt-2">Regular Adjustment</p>
          <p class="font-[family-name:var(--font-display)] text-6xl font-semibold text-white leading-none">${pricing.regularAdjustment.price}</p>
          <p class="text-light-blue-soft/70 text-sm mt-3">${pricing.regularAdjustment.studentChild} students/children</p>
          <hr class="my-6 border-white/10" />
          <p class="text-light-blue-soft/70 text-sm leading-relaxed">Targeted adjustment and check-in</p>
          <p class="text-light-blue-soft/50 text-xs mt-2">Approx. {pricing.regularAdjustment.duration}</p>
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="mt-6 block w-full text-center py-3.5 rounded-lg bg-light-blue hover:bg-light-blue-soft text-navy-deep font-semibold transition-colors">
            Book Now
          </a>
        </div>
        <!-- Baby -->
        <div class="bg-white rounded-xl p-8 text-center shadow-sm hover:shadow-lg transition-shadow">
          <p class="text-light-blue text-sm font-bold uppercase tracking-[0.15em] mb-4">Baby / Newborn</p>
          <p class="font-[family-name:var(--font-display)] text-5xl font-semibold text-navy leading-none">From ${pricing.babyNewborn.priceFrom}</p>
          <p class="text-grey-text text-sm mt-3">Initial ${pricing.babyNewborn.initial}</p>
          <hr class="my-6 border-grey-mid/20" />
          <p class="text-grey-text text-sm leading-relaxed">Gentle assessment for little ones</p>
          <p class="text-grey-text text-xs mt-2">{pricing.babyNewborn.duration}</p>
          <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="mt-6 block w-full text-center py-3.5 rounded-lg bg-navy-deep hover:bg-navy text-white font-medium transition-colors">
            Book Now
          </a>
        </div>
      </div>
      <p class="text-center text-grey-text text-sm mt-10">We accept {clinic.payment.join(', ')}. Health fund claims processed instantly with HICAPS.</p>
    </div>
  </section>

  <!-- ==================== CTA — Gradient background navy-deep to mid-blue ==================== -->
  <section class="py-24 md:py-32 bg-gradient-to-r from-navy-deep to-mid-blue relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -top-20 -right-20 w-96 h-96 bg-light-blue rounded-full blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-72 h-72 bg-light-blue rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-white mb-6 leading-tight">Ready to Make a Change?</h2>
      <p class="text-light-blue-soft text-xl leading-relaxed mb-12 max-w-2xl mx-auto">
        Stop letting pain hold you back. Book your first visit and take the first step towards feeling like yourself again.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-light-blue hover:bg-light-blue-soft text-navy-deep px-12 py-5 rounded-lg text-lg font-semibold transition-colors">
          Book Online Now
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white px-12 py-5 rounded-lg text-lg font-medium transition-colors">
          Call {clinic.phone}
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== AREAS SERVED — on dark background ==================== -->
  <section class="py-16 md:py-20 bg-navy-deep">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="text-light-blue text-sm font-bold uppercase tracking-[0.2em] mb-3">Our Reach</p>
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-white mb-4">Serving the Tweed & Gold Coast</h2>
        <p class="text-light-blue-soft/60">Conveniently located for residents across the border region.</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {areas.map((area) => (
          <a href={`/areas/${area.toLowerCase().replace(/\s+/g, '-')}`} class="bg-white/5 text-light-blue-soft text-sm px-5 py-2.5 rounded-lg border border-white/10 hover:bg-light-blue/10 hover:border-light-blue/30 hover:text-light-blue font-medium transition-all">
            {area}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== LOCATION — White section ==================== -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
          <p class="text-light-blue text-sm font-bold uppercase tracking-[0.2em] mb-3">Find Us</p>
          <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Visit Our Clinic</h2>
          <p class="text-grey-text leading-relaxed mb-6">Ground-level access on Greenway Drive in Tweed Heads South. Free on-site parking. Between Reece Plumbing and Border Bikes.</p>
          <div class="space-y-4">
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-light-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="text-navy font-medium">{clinic.address.full}</p>
                <p class="text-grey-text text-sm mt-0.5">{clinic.landmark}</p>
              </div>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-light-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href={`tel:${clinic.phoneFull}`} class="text-navy font-medium hover:text-light-blue transition-colors">{clinic.phone}</a>
            </div>
            <div class="flex gap-3">
              <svg class="w-5 h-5 text-light-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <div>
                <p class="text-navy font-medium">Open 6 days a week</p>
                <div class="text-grey-text text-sm mt-1 space-y-0.5">
                  {clinic.hours.filter(h => h.open !== 'Closed').map((h) => (
                    <p>{h.day}: {h.open} – {h.close}</p>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-light-grey rounded-xl overflow-hidden aspect-video shadow-lg">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3523.8!2d153.5375!3d-28.1894!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b911a6d7e2c0001%3A0x95d26a12c609fa2b!2s2%2F44+Greenway+Dr%2C+Tweed+Heads+South+NSW+2486!5e0!3m2!1sen!2sau"
