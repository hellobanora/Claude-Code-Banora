---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { clinic, practitioners, pricing } from '../../data/clinic';
import { areas } from '../../data/areas';
import { services } from '../../data/services';
import { conditions } from '../../data/conditions';

export function getStaticPaths() {
  return areas.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const otherAreas = areas.filter(a => a.slug !== area.slug).slice(0, 8);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: area.metaTitle,
  url: `${clinic.website}/areas/${area.slug}`,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: clinic.website },
      { '@type': 'ListItem', position: 2, name: 'Areas We Serve', item: `${clinic.website}/areas` },
      { '@type': 'ListItem', position: 3, name: area.name, item: `${clinic.website}/areas/${area.slug}` },
    ],
  },
};
---

<BaseLayout title={area.metaTitle} description={area.metaDescription} schema={schema}>
  <!-- Hero -->
  <section class="bg-navy relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep via-navy to-navy-light opacity-95"></div>
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-20 right-20 w-64 h-64 bg-light-blue rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <nav class="text-sm text-light-blue-soft/60 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white">{area.name}</span>
      </nav>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-white mb-4">{area.heroHeading}</h1>
      <div class="flex items-center gap-4 mt-4">
        <span class="bg-white/10 backdrop-blur-sm text-light-blue text-sm px-4 py-1.5 rounded-full">{area.distance} from our clinic</span>
        <span class="bg-white/10 backdrop-blur-sm text-light-blue text-sm px-4 py-1.5 rounded-full">{area.driveTime}</span>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy mb-4">Chiropractic Care for {area.name} Residents</h2>
            <p class="text-grey-text leading-relaxed text-lg">{area.description}</p>
          </div>

          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-3">Getting here from {area.name}</h3>
            <p class="text-grey-text leading-relaxed">{area.localInfo}</p>
          </div>

          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-3">Services for {area.name} patients</h3>
            <p class="text-grey-text leading-relaxed mb-6">{area.servicesHighlight}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {services.map((service) => (
                <a href={`/services/${service.slug}`} class="flex items-center gap-3 bg-blue-ghost/50 rounded-lg p-3 border border-blue-pale/20 hover:border-light-blue/40 transition-colors">
                  <span class="text-xl">{service.icon}</span>
                  <span class="text-sm text-navy font-medium">{service.title}</span>
                </a>
              ))}
            </div>
          </div>

          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-3">Conditions we help {area.name} patients with</h3>
            <div class="flex flex-wrap gap-2 mt-3">
              {conditions.map((condition) => (
                <a href={`/conditions/${condition.slug}`} class="text-sm bg-light-grey text-navy px-4 py-2 rounded-full border border-grey-mid/20 hover:border-light-blue transition-colors">
                  {condition.icon} {condition.title}
                </a>
              ))}
            </div>
          </div>

          <!-- Team -->
          <div>
            <h3 class="font-[family-name:var(--font-display)] text-xl font-semibold text-navy mb-4">Your chiropractors</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {practitioners.map((doc) => (
                <div class="bg-blue-ghost/30 rounded-lg p-4 flex items-center gap-4">
                  <div class="w-14 h-14 rounded-full overflow-hidden border border-blue-pale shrink-0">
                    <img src={`/images/dr-${doc.slug.split('-').slice(1).join('-')}.png`} alt={doc.name} class="w-full h-full object-cover" width="56" height="56" loading="lazy" />
                  </div>
                  <div>
                    <p class="text-navy font-medium text-sm">{doc.name}</p>
                    <p class="text-grey-text text-xs">{doc.qualifications}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-blue-ghost/50 rounded-xl p-6 border border-blue-pale/30">
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy mb-4">Book Your Visit</h3>
            <p class="text-grey-text text-sm mb-4">Just {area.driveTime} from {area.name}. Free parking, no steps.</p>
            <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="block w-full bg-mid-blue hover:bg-navy text-white text-center px-4 py-3 rounded-lg font-medium transition-colors mb-3">
              Book Online
            </a>
            <a href={`tel:${clinic.phoneFull}`} class="block w-full bg-white border border-grey-mid/30 text-navy text-center px-4 py-3 rounded-lg font-medium hover:border-mid-blue transition-colors">
              Call {clinic.phone}
            </a>
          </div>

          <div class="bg-light-grey rounded-xl p-6">
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy mb-3">Clinic Details</h3>
            <ul class="space-y-3 text-sm text-grey-text">
              <li class="flex gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                {clinic.address.full}
              </li>
              <li class="flex gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Free on-site parking
              </li>
              <li class="flex gap-2">
                <svg class="w-4 h-4 text-mid-blue mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                Wheelchair accessible
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-xl p-6 border border-grey-mid/20">
            <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold text-navy mb-3">Fees</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex justify-between"><span class="text-grey-text">New patient</span><span class="text-navy font-medium">${pricing.newPatient.price}</span></li>
              <li class="flex justify-between"><span class="text-grey-text">Regular adjustment</span><span class="text-navy font-medium">${pricing.regularAdjustment.price}</span></li>
              <li class="flex justify-between"><span class="text-grey-text">Student/child</span><span class="text-navy font-medium">From ${pricing.regularAdjustment.studentChild}</span></li>
            </ul>
            <p class="text-xs text-grey-text mt-3">HICAPS on-site for instant health fund claims</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Areas -->
  <section class="py-16 md:py-20 bg-light-grey">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-[family-name:var(--font-display)] text-2xl font-semibold text-navy mb-6 text-center">We Also Serve</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {otherAreas.map((a) => (
          <a href={`/areas/${a.slug}`} class="bg-white text-navy text-sm px-4 py-2 rounded-full border border-grey-mid/30 hover:border-light-blue hover:text-mid-blue transition-colors">
            {a.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-navy relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-10 right-10 w-72 h-72 bg-light-blue rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-white mb-4">{area.name} chiropractor — just {area.driveTime} away</h2>
      <p class="text-light-blue-soft/90 text-lg mb-8">Book online or call us. New patients welcome, no referral needed.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center bg-mid-blue hover:bg-light-blue text-white px-8 py-4 rounded-lg text-lg font-medium transition-colors">
          Book Online
        </a>
        <a href={`tel:${clinic.phoneFull}`} class="inline-flex items-center justify-center bg-white/10 hover:bg-white/20 text-white px-8 py-4 rounded-lg text-lg font-medium transition-colors">
          Call {clinic.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
