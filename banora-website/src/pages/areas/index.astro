---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { areas } from '../../data/areas';
import { clinic } from '../../data/clinic';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: clinic.website },
        { '@type': 'ListItem', position: 2, name: 'Areas We Serve', item: `${clinic.website}/areas` },
      ],
    },
    {
      '@type': 'LocalBusiness',
      '@id': clinic.website,
      name: clinic.name,
      telephone: clinic.phone,
      url: clinic.website,
      address: {
        '@type': 'PostalAddress',
        streetAddress: clinic.address.street,
        addressLocality: clinic.address.suburb,
        addressRegion: clinic.address.state,
        postalCode: clinic.address.postcode,
        addressCountry: 'AU',
      },
      areaServed: areas.map((a) => ({ '@type': 'City', name: a.name })),
    },
  ],
};
---

<BaseLayout
  title="Areas We Serve | Chiropractor Tweed Heads & Gold Coast | Banora Chiropractic"
  description="Banora Chiropractic serves Tweed Heads South, Tweed Heads, Banora Point, Coolangatta, Palm Beach, Currumbin, Elanora and surrounding Gold Coast suburbs. Book online today."
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-navy relative hero-overflow-clip">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-deep/95 via-navy/90 to-navy-light/85"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
      <nav class="text-sm text-light-blue-soft/60 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white">Areas We Serve</span>
      </nav>
      <h1 class="font-[family-name:var(--font-display)] text-4xl md:text-5xl font-semibold text-white mb-4">Areas We Serve</h1>
      <p class="text-light-blue-soft/80 text-lg max-w-2xl">
        Based in Tweed Heads South, we see patients from across the Tweed and southern Gold Coast. If you are nearby, we would love to help.
      </p>
    </div>
  </section>

  <!-- Areas Grid -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-navy mb-4">Serving the Tweed & Southern Gold Coast</h2>
        <p class="text-grey-text text-lg max-w-2xl mx-auto">
          Conveniently located at 2/44 Greenway Drive, Tweed Heads South — easy to get to from across the region.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-5">
        {areas.map((area) => (
          <a
            href={`/areas/${area.slug}`}
            class="group bg-white rounded-xl border border-grey-mid/20 shadow-sm hover:shadow-md hover:-translate-y-1 hover:border-mid-blue/30 transition-all duration-200 p-5 flex flex-col"
          >
            <div class="flex items-start gap-3 mb-2">
              <div class="w-8 h-8 bg-mid-blue/10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-mid-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-[family-name:var(--font-display)] font-semibold text-navy group-hover:text-mid-blue transition-colors leading-tight">
                  {area.name}
                </h3>
                <p class="text-xs text-grey-text mt-0.5">{area.driveTime}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="bg-navy py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-4xl font-semibold text-white mb-4">
        Close to you, ready to help
      </h2>
      <p class="text-light-blue-soft/80 text-lg mb-8 max-w-xl mx-auto">
        Most patients are within 15 minutes of our clinic. Book online or call us to make an appointment.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <button class="open-booking-modal bg-mid-blue hover:bg-light-blue text-white px-8 py-4 rounded-lg font-semibold text-lg transition-colors shadow-md">
          Book Online
        </button>
        <a href={`tel:${clinic.phoneFull}`} class="flex items-center gap-2 text-white hover:text-light-blue-soft transition-colors font-medium">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {clinic.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
