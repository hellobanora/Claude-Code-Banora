// ---- Choice button delegation ----
function attachChoiceListeners() {
  messages?.querySelectorAll('.bcb-choice:not([data-bound])').forEach(btn => {
    btn.dataset.bound = '1';
    btn.addEventListener('click', async () => {
      const action = btn.dataset.action;
      const value = btn.dataset.value;

      btn.closest('.flex')?.querySelectorAll('.bcb-choice').forEach(b => {
        b.disabled = true;
        b.style.opacity = '0.5';
      });

      if (action === 'patient-type') {
        await handlePatientType(value === 'new');
      } else if (action === 'practitioner') {
        const parsed = JSON.parse(value);
        userMsg(parsed.name);
        await handlePractitioner(parsed.id, parsed.name);
      } else if (action === 'service') {
        await handleService(value);
      } else if (action === 'start-booking') {
        await startBooking();
      }
    });
  });
}

// ---- Free text ----
async function handleFreeText(text) {
  const lower = text.toLowerCase();
  hideQuickBtns();

  if (/book|appointment|schedule|available|slot|time/i.test(lower)) {
    await startBooking();
  } else if (/hour|open|close|when.*open/i.test(lower)) {
    await botMsg("We're open Monday, Tuesday, Thursday 8:30am–6pm, Wednesday 2pm–6pm, Friday 12pm–2pm, and Saturday 8am–12pm.");
    setTimeout(() => botMsg("Want to grab a spot?", 400), 800);
  } else if (/cost|price|fee|how much|charge|bulk.?bill/i.test(lower)) {
    await botMsg("Initial consult is $100, follow-ups $72. Health fund rebates apply via HICAPS — most people pay about $15–25 gap. Want to book?");
  } else if (/new.?patient|first.?time|first.?visit|never.?been/i.test(lower)) {
    await botMsg("Welcome! First visit is 30–45 mins — full assessment, no referral needed. $100 initial consult.");
    setTimeout(() => botMsg("Want to grab a time?", 400), 800);
  } else if (/back.?pain|neck.?pain|sciatica|headache|migraine|shoulder|posture|spine|disc/i.test(lower)) {
    await botMsg("That's something we see all the time. Our chiropractors will assess what's going on and walk you through the best approach for you.");
    setTimeout(async () => {
      await botMsg("Want to book in? We can usually see you within a day or two.", 400);
    }, 800);
  } else if (/park|where|location|address|find|direction/i.test(lower)) {
    await botMsg("We're at 2/44 Greenway Drive, Tweed Heads South — ground level with free parking out front. Easy to find.");
  } else if (/health.?fund|insurance|private|hicaps|medicare|rebate/i.test(lower)) {
    await botMsg("We're registered with all major health funds and have HICAPS on-site for instant rebates. Most patients with cover pay about $15–25 out of pocket.");
  } else if (/phone|call|ring|speak|talk.*someone/i.test(lower)) {
    await botMsg(`Of course! Give us a call on <a href="tel:${phoneFull}" style="color:#2C5F8A;font-weight:600;text-decoration:underline">${phone}</a> — the team will sort you out.`);
  } else if (/thank|cheers|ta\b/i.test(lower)) {
    await botMsg("No worries at all! If you need anything else, just ask.");
  } else if (/hi\b|hey\b|hello|g'day|good morning|good afternoon/i.test(lower)) {
    await botMsg("Hey! Good to hear from you. Looking to book in, or have a question I can help with?");
  } else {
    await botMsg(`I might not have the answer to that one. Your best bet is to give us a call on <a href="tel:${phoneFull}" style="color:#2C5F8A;font-weight:600;text-decoration:underline">${phone}</a> — the team can help you out.`);
    setTimeout(async () => {
      await botMsg("Or I can walk you through booking right now if you'd like.", 400);
    }, 800);
  }
}

// ---- Send handler ----
function handleSend() {
  const text = input?.value?.trim();
  if (!text) return;
  userMsg(text);
  if (input) input.value = '';
  handleFreeText(text);
}

sendBtn?.addEventListener('click', handleSend);
input?.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') handleSend();
});

// ---- GA4 tracking ----
function trackEvent(name) {
  if (typeof gtag === 'function') {
    gtag('event', name, { event_category: 'chatbot' });
  }
}

// ---- Exit intent (desktop) ----
let exitShown = false;
document.addEventListener('mouseleave', (e) => {
  if (e.clientY < 10 && !chatOpen && !exitShown) {
    exitShown = true;
    nudge?.classList.remove('hidden');
    const nudgeText = nudge?.querySelector('p');
    if (nudgeText) nudgeText.innerHTML = "Heading off? <strong>Book online in under 60 seconds.</strong>";
    trackEvent('exit_intent_shown');
  }
});
</script>
