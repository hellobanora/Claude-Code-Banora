---
import { clinic } from '../../data/clinic';
---

<!-- Conversational Booking Chatbot — IconPractice API integration -->

<!-- Floating toggle button -->
<div id="bcb-widget" class="fixed bottom-20 right-4 lg:bottom-6 lg:right-6 z-50">
  <!-- Pulse ring -->
  <div id="bcb-pulse" class="absolute inset-0 rounded-full animate-ping pointer-events-none" style="background:rgba(212,168,83,0.35)"></div>

  <!-- Toggle button -->
  <button
    id="bcb-toggle"
    class="relative w-16 h-16 text-white rounded-full shadow-lg hover:shadow-xl transition-all duration-300 flex items-center justify-center"
    style="background:linear-gradient(135deg,#D4A853,#B88E3A)"
    aria-label="Chat with us — book an appointment"
    onmouseover="this.style.background='linear-gradient(135deg,#B88E3A,#9A7530)'"
    onmouseout="this.style.background='linear-gradient(135deg,#D4A853,#B88E3A)'"
  >
    <!-- Chat icon -->
    <svg id="bcb-icon-chat" class="w-7 h-7 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <!-- Close icon -->
    <svg id="bcb-icon-close" class="w-7 h-7 hidden transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <!-- Nudge bubble -->
  <div id="bcb-nudge" class="hidden absolute bottom-20 right-0 bg-white rounded-2xl shadow-xl p-4 w-72 border border-gray-200">
    <button id="bcb-nudge-close" class="absolute top-2 right-2 text-gray-400 hover:text-gray-600 transition-colors" aria-label="Dismiss">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
    <p class="text-sm text-gray-700 leading-relaxed mb-3">Got a sore back? We can usually get you in <strong>this week</strong>.</p>
    <button id="bcb-nudge-book" class="w-full text-white text-sm font-medium py-2.5 px-4 rounded-lg transition-colors" style="background:#D4A853" onmouseover="this.style.background='#B88E3A'" onmouseout="this.style.background='#D4A853'">
      Book an appointment
    </button>
  </div>
</div>

<!-- Chat window -->
<div id="bcb-window" class="fixed bottom-20 right-4 lg:bottom-6 lg:right-6 z-50 hidden">
  <div class="w-[360px] max-w-[calc(100vw-2rem)] h-[560px] max-h-[calc(100vh-8rem)] bg-white rounded-2xl shadow-2xl border border-gray-200 flex flex-col overflow-hidden">

    <!-- Header -->
    <div style="background:#1B3A5C" class="px-5 py-4 flex items-center justify-between flex-shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full flex items-center justify-center" style="background:rgba(255,255,255,0.1)">
          <img src="/images/logo-square.png" alt="" class="w-7 h-7 rounded-full" />
        </div>
        <div>
          <h3 class="text-white text-sm font-semibold">Banora Chiropractic</h3>
          <div class="flex items-center gap-1.5">
            <span class="w-2 h-2 bg-green-400 rounded-full"></span>
            <span class="text-xs" style="color:rgba(255,255,255,0.7)">Online — ready to book</span>
          </div>
        </div>
      </div>
      <button id="bcb-close" class="transition-colors" style="color:rgba(255,255,255,0.6)" aria-label="Close chat">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Messages container -->
    <div id="bcb-messages" class="flex-1 overflow-y-auto px-4 py-4 space-y-3 bg-[#f8f9fa]">
      <!-- Initial welcome message -->
      <div class="flex gap-2.5">
        <div class="w-7 h-7 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5" style="background:rgba(27,58,92,0.1)">
          <img src="/images/logo-square.png" alt="" class="w-5 h-5 rounded-full" />
        </div>
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm max-w-[85%]">
          <p class="text-sm text-gray-800 leading-relaxed">Hey! I can help you book an appointment or answer questions about the clinic. What brings you here today?</p>
        </div>
      </div>
    </div>

    <!-- Input area -->
    <div class="px-4 py-3 bg-white border-t border-gray-100 flex-shrink-0">
      <!-- Quick buttons -->
      <div id="bcb-quick-btns" class="flex flex-wrap gap-2 mb-3">
        <button id="bcb-qb-book" class="text-white text-xs font-medium px-4 py-2 rounded-full transition-colors" style="background:#D4A853" onmouseover="this.style.background='#B88E3A'" onmouseout="this.style.background='#D4A853'">
          Book now
        </button>
        <button id="bcb-qb-hours" class="bg-blue-50 text-xs font-medium px-3 py-2 rounded-full hover:bg-blue-100 transition-colors" style="color:#1B3A5C">
          Opening hours
        </button>
        <button id="bcb-qb-new" class="bg-blue-50 text-xs font-medium px-3 py-2 rounded-full hover:bg-blue-100 transition-colors" style="color:#1B3A5C">
          New patient
        </button>
        <button id="bcb-qb-cost" class="bg-blue-50 text-xs font-medium px-3 py-2 rounded-full hover:bg-blue-100 transition-colors" style="color:#1B3A5C">
          How much?
        </button>
      </div>

      <!-- Text input + send -->
      <div class="flex items-center gap-2">
        <input
          id="bcb-input"
          type="text"
          placeholder="Type your message..."
          class="flex-1 text-sm bg-[#f8f9fa] border border-gray-200 rounded-full px-4 py-2.5 focus:outline-none focus:border-blue-400 transition-colors text-gray-800 placeholder:text-gray-400"
        />
        <button id="bcb-send" class="w-10 h-10 text-white rounded-full flex items-center justify-center transition-colors flex-shrink-0" style="background:#2C5F8A" aria-label="Send message">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
        </button>
      </div>
    </div>

  </div>
</div>

<script define:vars={{ bookingUrl: clinic.bookingUrl, phone: clinic.phone, phoneFull: clinic.phoneFull }}>
// =====================================================
// BANORA CHIROPRACTIC — CONVERSATIONAL BOOKING CHATBOT
// IconPractice API integration via /api/booking proxy
// =====================================================

const $ = (id) => document.getElementById(id);

// UI refs
const toggle = $('bcb-toggle');
const iconChat = $('bcb-icon-chat');
const iconClose = $('bcb-icon-close');
const pulse = $('bcb-pulse');
const nudge = $('bcb-nudge');
const window_ = $('bcb-window');
const messages = $('bcb-messages');
const input = $('bcb-input');
const sendBtn = $('bcb-send');
const quickBtns = $('bcb-quick-btns');

// Booking state
const bk = {
  isNew: null,
  practiceId: null,
  customerId: null,
  practitionerId: null,
  practitionerName: '',
  serviceId: null,
  serviceName: '',
  servicePrice: null,
  serviceDuration: null,
  selectedDate: null,
  selectedTime: null,
  selectedTimeEnd: null,
  selectedTimeLabel: null,
  csrfKey: null,
  csrfToken: null,
  practitioners: [],
  calMonth: new Date().getMonth() + 1,
  calYear: new Date().getFullYear(),
};

let chatOpen = false;
let quickBtnsHidden = false;

// ---- Nudge timer ----
const nudgeTimer = setTimeout(() => {
  if (!chatOpen) {
    nudge?.classList.remove('hidden');
    setTimeout(() => nudge?.classList.add('hidden'), 12000);
  }
}, 8000);

// Stop pulse after 5s
setTimeout(() => pulse?.classList.add('hidden'), 5000);

// ---- Open / close ----
function openChat() {
  chatOpen = true;
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: 'chatbot_open' });
  window_?.classList.remove('hidden');
  iconChat?.classList.add('hidden');
  iconClose?.classList.remove('hidden');
  nudge?.classList.add('hidden');
  clearTimeout(nudgeTimer);
  input?.focus();
  trackEvent('chatbot_opened');
}

function closeChat() {
  chatOpen = false;
  window_?.classList.add('hidden');
  iconChat?.classList.remove('hidden');
  iconClose?.classList.add('hidden');
}

toggle?.addEventListener('click', openChat);
$('bcb-close')?.addEventListener('click', closeChat);
$('bcb-nudge-close')?.addEventListener('click', () => nudge?.classList.add('hidden'));
$('bcb-nudge-book')?.addEventListener('click', () => {
  openChat();
  setTimeout(() => startBooking(), 300);
});

// ---- Message helpers ----
function botAvatar() {
  return `<div class="w-7 h-7 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5" style="background:rgba(27,58,92,0.1)">
    <img src="/images/logo-square.png" alt="" class="w-5 h-5 rounded-full" />
  </div>`;
}

function typingDots() {
  const el = document.createElement('div');
  el.className = 'bcb-typing flex gap-2.5';
  el.innerHTML = `${botAvatar()}
    <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm">
      <div class="flex gap-1">
        <span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:0ms"></span>
        <span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:150ms"></span>
        <span class="w-2 h-2 bg-gray-300 rounded-full animate-bounce" style="animation-delay:300ms"></span>
      </div>
    </div>`;
  return el;
}

function scrollBottom() {
  if (messages) messages.scrollTop = messages.scrollHeight;
}

function botMsg(html, delay = 500) {
  return new Promise((resolve) => {
    const dots = typingDots();
    messages?.appendChild(dots);
    scrollBottom();
    setTimeout(() => {
      dots.remove();
      const el = document.createElement('div');
      el.className = 'flex gap-2.5';
      el.innerHTML = `${botAvatar()}
        <div class="bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm max-w-[85%]">
          <div class="text-sm text-gray-800 leading-relaxed">${html}</div>
        </div>`;
      messages?.appendChild(el);
      scrollBottom();
      resolve(el);
    }, delay);
  });
}

function interactiveEl(html, delay = 600) {
  return new Promise((resolve) => {
    const dots = typingDots();
    messages?.appendChild(dots);
    scrollBottom();
    setTimeout(() => {
      dots.remove();
      const el = document.createElement('div');
      el.className = 'w-full';
      el.innerHTML = html;
      messages?.appendChild(el);
      scrollBottom();
      resolve(el);
    }, delay);
  });
}

function userMsg(text) {
  const el = document.createElement('div');
  el.className = 'flex justify-end';
  el.innerHTML = `<div class="text-white rounded-2xl rounded-tr-sm px-4 py-3 shadow-sm max-w-[85%]" style="background:#2C5F8A">
    <p class="text-sm leading-relaxed">${text}</p>
  </div>`;
  messages?.appendChild(el);
  scrollBottom();
}

function hideQuickBtns() {
  if (!quickBtnsHidden) {
    quickBtnsHidden = true;
    quickBtns?.classList.add('hidden');
  }
}

function choiceButtons(choices) {
  const wrap = document.createElement('div');
  wrap.className = 'flex flex-wrap gap-2 mt-2 ml-9';
  choices.forEach(({ label, value, action }) => {
    const btn = document.createElement('button');
    btn.className = 'bcb-choice text-xs font-medium px-4 py-2 rounded-full border border-gray-200 bg-white hover:bg-blue-50 transition-colors text-gray-700';
    btn.textContent = label;
    btn.dataset.value = value;
    btn.dataset.action = action;
    wrap.appendChild(btn);
  });
  messages?.appendChild(wrap);
  scrollBottom();
  attachChoiceListeners();
  return wrap;
}

// ---- Calendar ----
function buildCalendar(year, month, schedule) {
  const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const dayNames = ['Su','Mo','Tu','We','Th','Fr','Sa'];
  const firstDay = new Date(year, month - 1, 1).getDay();
  const daysInMonth = new Date(year, month, 0).getDate();

  // Build lookup: day number -> available + times
  const avail = {};
  (schedule || []).forEach(s => {
    const times = s.time || s.times || [];
    if (times.length > 0) avail[s.day] = times;
  });

  let cells = '';
  // Day header
  cells += `<div class="grid grid-cols-7 gap-1 mb-1">${dayNames.map(d => `<div class="text-center text-xs text-gray-400 font-medium py-1">${d}</div>`).join('')}</div>`;
  cells += `<div class="grid grid-cols-7 gap-1">`;
  // Empty cells before first day
  for (let i = 0; i < firstDay; i++) cells += `<div></div>`;
  for (let d = 1; d <= daysInMonth; d++) {
    const isAvail = !!avail[d];
    if (isAvail) {
      cells += `<button class="bcb-cal-day text-xs font-medium py-1.5 rounded-lg text-white hover:opacity-80 transition-opacity" style="background:#2C5F8A" data-date="${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}" data-day="${d}">${d}</button>`;
    } else {
      cells += `<div class="text-xs text-gray-300 py-1.5 text-center">${d}</div>`;
    }
  }
  cells += `</div>`;

  const prevMonth = month === 1 ? 12 : month - 1;
  const prevYear = month === 1 ? year - 1 : year;
  const nextMonth = month === 12 ? 1 : month + 1;
  const nextYear = month === 12 ? year + 1 : year;

  const today = new Date();
  const isPast = (year < today.getFullYear()) || (year === today.getFullYear() && month <= today.getMonth() + 1);

  return `<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-3 mx-0 mt-1">
    <div class="flex items-center justify-between mb-3">
      ${!isPast ? `<button class="bcb-cal-prev text-gray-400 hover:text-gray-700 transition-colors p-1" data-month="${prevMonth}" data-year="${prevYear}">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>` : `<div class="w-6"></div>`}
      <span class="text-sm font-semibold text-gray-700">${monthNames[month-1]} ${year}</span>
      <button class="bcb-cal-next text-gray-400 hover:text-gray-700 transition-colors p-1" data-month="${nextMonth}" data-year="${nextYear}">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
    </div>
    ${cells}
    <p class="text-xs text-gray-400 mt-2 text-center">Tap a highlighted date to see available times</p>
  </div>`;
}

function buildTimeSlots(times) {
  if (!times || times.length === 0) return '<p class="text-sm text-gray-500 ml-9">No times available for this date.</p>';
  const formatted = times.map(t => {
    const label = t.start || t;
    const value = encodeURIComponent(JSON.stringify({ ts: t.ts_start, tsEnd: t.ts_end, label }));
    return `<button class="bcb-time text-xs font-medium px-3 py-1.5 rounded-lg border border-gray-200 bg-white hover:bg-blue-50 transition-colors text-gray-700" data-time="${value}">${label}</button>`;
  }).join('');
  return `<div class="flex flex-wrap gap-2 mt-1 ml-9">${formatted}</div>`;
}

function buildDetailsForm() {
  return `<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4 mt-1">
    <p class="text-sm font-semibold text-gray-700 mb-3">Your details</p>
    <div class="space-y-2.5">
      <div class="grid grid-cols-2 gap-2">
        <div>
          <label class="text-xs text-gray-500 block mb-1">First name *</label>
          <input id="bcb-fn" type="text" placeholder="Jane" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-400" />
        </div>
        <div>
          <label class="text-xs text-gray-500 block mb-1">Last name *</label>
          <input id="bcb-ln" type="text" placeholder="Smith" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-400" />
        </div>
      </div>
      <div>
        <label class="text-xs text-gray-500 block mb-1">Date of birth * (DD/MM/YYYY)</label>
        <input id="bcb-dob" type="text" placeholder="15/06/1985" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-400" />
      </div>
      <div>
        <label class="text-xs text-gray-500 block mb-1">Email *</label>
        <input id="bcb-email" type="email" placeholder="jane@example.com" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-400" />
      </div>
      <div>
        <label class="text-xs text-gray-500 block mb-1">Mobile *</label>
        <input id="bcb-mobile" type="tel" placeholder="0400 000 000" class="w-full text-sm border border-gray-200 rounded-lg px-3 py-2 focus:outline-none focus:border-blue-400" />
      </div>
      <button id="bcb-confirm-btn" class="w-full text-white text-sm font-semibold py-3 rounded-xl transition-colors mt-1" style="background:#1B3A5C" onmouseover="this.style.background='#2C5F8A'" onmouseout="this.style.background='#1B3A5C'">
        Confirm booking
      </button>
      <p class="text-xs text-gray-400 text-center">Your info is only used for your appointment</p>
    </div>
  </div>`;
}

// ---- Booking flow ----
async function startBooking() {
  hideQuickBtns();
  trackEvent('booking_started');
  await botMsg("Great! Let me help you book. Are you a new patient or have you visited us before?");
  choiceButtons([
    { label: "New patient", value: "new", action: "patient-type" },
    { label: "Existing patient", value: "existing", action: "patient-type" },
  ]);
}

async function handlePatientType(isNew) {
  bk.isNew = isNew;
  userMsg(isNew ? "New patient" : "Existing patient");
  await botMsg("Perfect. Let me check who's available...");

  try {
    // Fetch practices
    const practicesRes = await fetch('/api/booking?action=practices');
    const practicesData = await practicesRes.json();
    const pd = practicesData.details || practicesData;
    const allPractices = pd.practices || [];
    const practice = allPractices.find(p =>
      p.name?.toLowerCase().includes('banora') ||
      p.address?.toLowerCase().includes('greenway')
    ) || allPractices[0];
    if (!practice) throw new Error('No practice found');
    bk.practiceId = practice.id;
    bk.customerId = pd.customer_id;

    // Fetch practice details (practitioners + CSRF)
    // Note: tokens are injected server-side by the proxy
    const detailsRes = await fetch(`/api/booking?action=practice-details&practice_id=${bk.practiceId}`);
    const detailsData = await detailsRes.json();

    const dd = detailsData.details || detailsData;
    bk.csrfKey = dd.csrf_key;
    bk.csrfToken = dd.csrf_token;

    // "practioners" (API typo — missing 'i')
    const practitioners = dd.practioners || dd.practitioners || [];
    bk.practitioners = practitioners;

    if (practitioners.length === 0) throw new Error('No practitioners found');

    if (practitioners.length === 1) {
      const p = practitioners[0];
      await handlePractitioner(p.id, `${p.title} ${p.firstname} ${p.lastname}`.trim());
    } else {
      await botMsg("Who would you like to see?");
      choiceButtons(practitioners.map(p => ({
        label: `${p.title} ${p.firstname} ${p.lastname}`.trim(),
        value: JSON.stringify({ id: p.id, name: `${p.title} ${p.firstname} ${p.lastname}`.trim() }),
        action: 'practitioner',
      })));
    }
  } catch (err) {
    console.error('handlePatientType error:', err);
    await botMsg("Sorry, I had trouble loading the booking details. You can still book easily below:");
    addCallFallback();
  }
}

async function handlePractitioner(id, name) {
  bk.practitionerId = id;
  bk.practitionerName = name;

  try {
    const existingParam = !bk.isNew; // true = existing patient, false = new
    const url = `/api/booking?action=practitioner-services&customer_id=${bk.customerId}&practice_id=${bk.practiceId}&practitioner_id=${id}&existing=${existingParam}`;
    const res = await fetch(url);
    const data = await res.json();
    console.log('Services API response:', JSON.stringify(data));
    const services = (data.details || data).services || [];

    if (services.length === 0) throw new Error('No services found');

    await botMsg(`Great — seeing ${name}. Which service do you need?`);
    choiceButtons(services.map(svc => ({
      label: `${svc.desc}${svc.fee ? ` — $${svc.fee}` : ''}`,
      value: JSON.stringify(svc),
      action: 'service',
    })));
  } catch (err) {
    console.error('handlePractitioner error:', err);
    await botMsg("I couldn't load the services right now. Let's get you sorted another way:");
    addCallFallback();
  }
}

async function handleService(svcJson) {
  let svc;
  try { svc = typeof svcJson === 'string' ? JSON.parse(svcJson) : svcJson; } catch { svc = {}; }

  bk.serviceId = svc.id;
  bk.serviceName = svc.desc || 'Appointment';
  bk.servicePrice = svc.fee || null;
  bk.serviceDuration = svc.duration || 45;

  userMsg(bk.serviceName);
  await botMsg("Let me find available times for you...");
  await fetchAndShowCalendar(bk.calMonth, bk.calYear);
}

async function fetchAndShowCalendar(month, year) {
  bk.calMonth = month;
  bk.calYear = year;

  try {
    // Note: API uses "practioner" (typo) for this param
    const url = `/api/booking?action=month-schedule&customer_id=${bk.customerId}&practice_id=${bk.practiceId}&practioner=${bk.practitionerId}&service_item_id=${bk.serviceId}&month=${month}&year=${year}&group=false&new_patient=${bk.isNew}`;
    const res = await fetch(url);
    const data = await res.json();
    const schedule = (data.details || data).schedule || [];

    const calHtml = buildCalendar(year, month, schedule);
    await interactiveEl(calHtml);

    // Bind calendar day buttons
    messages?.querySelectorAll('.bcb-cal-day:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        handleDateSelect(btn.dataset.date, parseInt(btn.dataset.day));
      });
    });

    // Bind prev/next
    messages?.querySelectorAll('.bcb-cal-prev:not([data-bound]), .bcb-cal-next:not([data-bound])').forEach(btn => {
      btn.dataset.bound = '1';
      btn.addEventListener('click', async () => {
        await fetchAndShowCalendar(parseInt(btn.dataset.month), parseInt(btn.dataset.year));
      });
    });

  } catch (err) {
    console.error('fetchAndShowCalendar error:', err);
    await botMsg("I had trouble loading the calendar. Let me help you another way:");
    addCallFallback();
  }
}

async function handleDateSelect(dateStr, dayNum) {
  bk.selectedDate = dateStr;

  // Find times for this day from the last schedule fetch
  const url = `/api/booking?action=month-schedule&customer_id=${bk.customerId}&practice_id=${bk.practiceId}&practioner=${bk.practitionerId}&service_item_id=${bk.serviceId}&month=${bk.calMonth}&year=${bk.calYear}&group=false&new_patient=${bk.isNew}`;

  try {
    const res = await fetch(url);
    const data = await res.json();
    const dayEntry = ((data.details || data).schedule || []).find(s => s.day === dayNum);
    const times = dayEntry ? (dayEntry.time || dayEntry.times || []) : [];

    const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const [y, m, d] = dateStr.split('-');
    const dateLabel = `${parseInt(d)} ${monthNames[parseInt(m)-1]} ${y}`;

    await botMsg(`Available times on ${dateLabel}:`);
    const slotsHtml = buildTimeSlots(times);
    const slotEl = document.createElement('div');
    slotEl.innerHTML = slotsHtml;
    messages?.appendChild(slotEl);
    scrollBottom();

    // Bind time buttons
    slotEl.querySelectorAll('.bcb-time').forEach(btn => {
      btn.addEventListener('click', () => {
        try {
          const d = JSON.parse(decodeURIComponent(btn.dataset.time));
          handleTimeSelect(d.ts, d.tsEnd, d.label);
        } catch {
          handleTimeSelect(btn.dataset.time, null, btn.dataset.time);
        }
      });
    });
  } catch (err) {
    console.error('handleDateSelect error:', err);
    await botMsg("Couldn't load times for that date. Please try another day or call us.");
  }
}

async function handleTimeSelect(ts, tsEnd, label) {
  bk.selectedTime = ts;
  bk.selectedTimeEnd = tsEnd;
  bk.selectedTimeLabel = label;

  userMsg(label);
  await botMsg(`${label} it is! Just need a few details to confirm your booking:`);
  await interactiveEl(buildDetailsForm());

  // Bind confirm button
  $('bcb-confirm-btn')?.addEventListener('click', handleConfirm);
}

async function handleConfirm() {
  const fn = $('bcb-fn')?.value?.trim();
  const ln = $('bcb-ln')?.value?.trim();
  const dob = $('bcb-dob')?.value?.trim();
  const email = $('bcb-email')?.value?.trim();
  const mobile = $('bcb-mobile')?.value?.trim();

  if (!fn || !ln || !dob || !email || !mobile) {
    await botMsg("Please fill in all the required fields before confirming.");
    return;
  }

  // Validate DOB format (DD/MM/YYYY) and convert to YYYY-MM-DD for API
  if (!/^\d{2}\/\d{2}\/\d{4}$/.test(dob)) {
    await botMsg("Please enter your date of birth as DD/MM/YYYY (e.g. 15/06/1985).");
    return;
  }
  const [dobD, dobM, dobY] = dob.split('/');
  const dobApi = `${dobY}-${dobM}-${dobD}`;

  const body = {
    practice_id: bk.practiceId,
    practitioner_id: bk.practitionerId,
    service_item_id: bk.serviceId,
    is_group: "false",
    existing: bk.isNew ? "false" : "true", // "true" = existing patient, "false" = new
    ts_schedule_start: bk.selectedTime,
    ts_schedule_end: bk.selectedTimeEnd,
    customer_firstname: fn,
    customer_lastname: ln,
    customer_dob: dobApi,
    customer_email: email,
    customer_mobile: mobile,
    csrf_key: bk.csrfKey,
    csrf_token: bk.csrfToken,
  };

  // Disable confirm button
  const confirmBtn = $('bcb-confirm-btn');
  if (confirmBtn) {
    confirmBtn.disabled = true;
    confirmBtn.textContent = 'Confirming...';
  }

  try {
    const res = await fetch('/api/booking', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();

    if (data.success === false) {
      console.error('Booking API response:', JSON.stringify(data));
      throw new Error(data.message || data.error || 'Booking failed');
    }

    // Format date for confirmation
    const [y, mo, d] = bk.selectedDate.split('-');
    const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const dateObj = new Date(parseInt(y), parseInt(mo) - 1, parseInt(d));
    const dayName = dayNames[dateObj.getDay()];
    const dateLabel = `${dayName} ${parseInt(d)} ${monthNames[parseInt(mo)-1]}`;

    const timeLabel = bk.selectedTimeLabel || '';

    trackEvent('booking_completed');

    await botMsg(`🎉 You're all booked!<br><br>
      📅 ${dateLabel} at ${timeLabel}<br>
      👨‍⚕️ ${bk.practitionerName}<br>
      📍 2/44 Greenway Drive, Tweed Heads South<br>
      ${bk.servicePrice ? `💰 ${bk.serviceName} — $${bk.servicePrice}` : `💰 ${bk.serviceName}`}<br><br>
      A confirmation will be sent to ${email}. See you then!`);

  } catch (err) {
    console.error('handleConfirm error:', err);
    if (confirmBtn) {
      confirmBtn.disabled = false;
      confirmBtn.textContent = 'Confirm booking';
    }
    await botMsg("Something went wrong with the booking. Please try again or give us a call:");
    addCallFallback();
  }
}

// ---- Fallback ----
async function addCallFallback() {
  const el = document.createElement('div');
  el.className = 'flex gap-2 ml-9 mt-1';
  el.innerHTML = `
    <a href="${bookingUrl}" target="_blank" rel="noopener noreferrer" class="text-white text-xs font-medium px-4 py-2 rounded-full transition-colors" style="background:#2C5F8A">
      Book online
    </a>
    <a href="tel:${phoneFull}" class="bg-blue-50 text-xs font-medium px-4 py-2 rounded-full hover:bg-blue-100 transition-colors flex items-center gap-1" style="color:#1B3A5C">
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      Call us
    </a>`;
  messages?.appendChild(el);
  scrollBottom();
}

// ---- Quick action buttons ----
$('bcb-qb-book')?.addEventListener('click', () => {
