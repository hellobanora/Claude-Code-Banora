---
import { clinic } from '../../data/clinic';
---

<!-- ================================================================
  BANORA CHIROPRACTIC — PREMIUM BOOKING MODAL
  Full multi-step booking via IconPractice API
  Trigger: add class "open-booking-modal" to any button or link
================================================================ -->

<!-- Overlay -->
<div id="bm-overlay" class="fixed inset-0 z-[300] hidden" aria-modal="true" role="dialog" aria-label="Book an appointment">

  <!-- Backdrop -->
  <div id="bm-backdrop" class="absolute inset-0" style="background:rgba(10,31,53,0.75);backdrop-filter:blur(3px)"></div>

  <!-- Panel wrapper (centres the panel and enables scroll on mobile) -->
  <div class="relative h-full flex items-center justify-center p-4 overflow-y-auto">

    <!-- Modal panel -->
    <div class="relative w-full max-w-[820px] bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col md:flex-row my-auto" style="min-height:580px;max-height:90vh">

      <!-- Close button -->
      <button
        id="bm-close"
        class="absolute top-4 right-4 z-20 w-9 h-9 flex items-center justify-center rounded-full transition-colors"
        style="background:rgba(255,255,255,0.15);color:#fff"
        aria-label="Close"
        onmouseover="this.style.background='rgba(255,255,255,0.25)'"
        onmouseout="this.style.background='rgba(255,255,255,0.15)'"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <!-- ── LEFT SIDEBAR (desktop) ── -->
      <div class="hidden md:flex flex-col w-[220px] flex-shrink-0 px-7 py-8" style="background:#1B3A5C">

        <!-- Logo + brand -->
        <div class="mb-7">
          <img src="/images/logo-horizontal.png" alt="Banora Chiropractic" class="mb-6 w-full object-contain" style="max-width:180px;height:auto;filter:brightness(0) invert(1);opacity:0.95" width="180" height="116" />
          <h2 class="text-white text-lg font-semibold leading-snug">Book an Appointment</h2>
          <p class="text-xs mt-1" style="color:rgba(255,255,255,0.5)">Banora Chiropractic<br/>Tweed Heads South</p>
        </div>

        <!-- Step progress -->
        <div id="bm-sidebar-steps" class="flex-1 space-y-1"></div>

        <!-- Bottom info -->
        <div class="pt-6 space-y-2" style="color:rgba(255,255,255,0.45)">
          <div class="flex items-center gap-2 text-xs">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            2/44 Greenway Drive, THS
          </div>
          <div class="flex items-center gap-2 text-xs">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            {clinic.phone}
          </div>
        </div>
      </div>

      <!-- ── RIGHT CONTENT ── -->
      <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Mobile header -->
        <div class="md:hidden flex items-center gap-3 px-5 py-4 flex-shrink-0" style="background:#1B3A5C">
          <img src="/images/logo-horizontal.png" alt="" class="flex-shrink-0 object-contain" style="height:40px;width:auto;filter:brightness(0) invert(1);opacity:0.95" width="155" height="40" />
          <div>
            <p class="text-white text-sm font-semibold">Book an Appointment</p>
            <p id="bm-mobile-step" class="text-xs" style="color:rgba(255,255,255,0.55)">Banora Chiropractic</p>
          </div>
        </div>

        <!-- Step content area -->
        <div id="bm-content" class="flex-1 overflow-y-auto px-6 py-7 md:px-8 md:py-8">
          <!-- Injected by JS -->
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  /* ── Booking modal step card styles ── */
  .bm-option-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    border: 2px solid #e5e7eb;
    background: #fff;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
    text-align: left;
  }
  .bm-option-card:hover {
    border-color: #D4A853;
    background: #FFFBF3;
    box-shadow: 0 2px 8px rgba(212,168,83,0.15);
  }
  .bm-option-card.selected {
    border-color: #D4A853;
    background: #FFFBF3;
  }
  .bm-practitioner-card {
    align-items: center;
    min-height: 80px;
    gap: 1.25rem;
  }
  .bm-practitioner-card img {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    flex-shrink: 0;
  }
  .bm-cal-day-available {
    background: #2C5F8A;
    color: #fff;
    border-radius: 8px;
    padding: 6px 4px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.1s, transform 0.1s;
    text-align: center;
  }
  .bm-cal-day-available:hover {
    background: #D4A853;
    transform: scale(1.05);
  }
  .bm-cal-day-available.selected {
    background: #D4A853;
  }
  .bm-time-btn {
    padding: 10px 14px;
    border-radius: 10px;
    border: 2px solid #e5e7eb;
    background: #fff;
    font-size: 0.85rem;
    font-weight: 500;
    color: #1B3A5C;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }
  .bm-time-btn:hover {
    border-color: #D4A853;
    background: #FFFBF3;
  }
  .bm-time-btn.selected {
    border-color: #D4A853;
    background: #FFFBF3;
  }
  .bm-input {
    width: 100%;
    padding: 10px 14px;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    font-size: 0.9rem;
    color: #1a1a1a;
    outline: none;
    transition: border-color 0.15s;
    background: #fff;
  }
  .bm-input:focus {
    border-color: #2C5F8A;
  }
  .bm-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    color: #6b7280;
    margin-bottom: 5px;
  }
  .bm-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #e5e7eb;
    border-top-color: #D4A853;
    border-radius: 50%;
    animation: bm-spin 0.7s linear infinite;
  }
  @keyframes bm-spin { to { transform: rotate(360deg); } }
  .bm-sidebar-step {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .bm-sidebar-step.active {
    background: rgba(255,255,255,0.1);
  }
  .bm-step-dot {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.7rem;
    font-weight: 700;
    border: 2px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.35);
  }
  .bm-step-dot.active {
    background: #D4A853;
    border-color: #D4A853;
    color: #fff;
  }
  .bm-step-dot.done {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.7);
  }
</style>

<script define:vars={{ phone: clinic.phone, phoneFull: clinic.phoneFull }}>
// ================================================================
// BANORA — PREMIUM BOOKING MODAL
// ================================================================

const overlay   = document.getElementById('bm-overlay');
const backdrop  = document.getElementById('bm-backdrop');
const closeBtn  = document.getElementById('bm-close');
const content   = document.getElementById('bm-content');
const sideSteps = document.getElementById('bm-sidebar-steps');
const mobileStep = document.getElementById('bm-mobile-step');

// ── Booking state ──
const bm = {
  isNew: null,
  practiceId: null,
  customerId: null,
  csrfKey: null,
  csrfToken: null,
  practitioners: [],
  practitionerId: null,
  practitionerName: '',
  services: [],
  serviceId: null,
  serviceName: '',
  servicePrice: null,
  serviceDuration: null,
  schedule: [],
  calMonth: new Date().getMonth() + 1,
  calYear: new Date().getFullYear(),
  selectedDate: null,
  selectedDateLabel: '',
  selectedTime: null,
  selectedTimeEnd: null,
  selectedTimeLabel: '',
};

// ── Steps config ──
const STEPS_CONFIG = [
  { key: 'patient-type', label: 'Patient type' },
  { key: 'service',      label: 'Service'       },
  { key: 'date',         label: 'Date'          },
  { key: 'time',         label: 'Time'          },
  { key: 'details',      label: 'Your details'  },
];
let currentStep = 'patient-type';

// ── Open / close ──
function openModal() {
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: 'book_appointment', method: 'booking_modal' });
  overlay.classList.remove('hidden');
  overlay.style.display = 'flex';
  document.body.style.overflow = 'hidden';
  resetAndStart();
  if (typeof window.trackEvent === 'function') window.trackEvent('booking_modal_opened');
}

function closeModal() {
  overlay.style.display = 'none';
  overlay.classList.add('hidden');
  document.body.style.overflow = '';
}

closeBtn?.addEventListener('click', closeModal);
backdrop?.addEventListener('click', closeModal);
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

// Global trigger — any element with class open-booking-modal
document.addEventListener('click', (e) => {
  if (e.target.closest('.open-booking-modal')) {
    e.preventDefault();
    openModal();
  }
});

// ── Sidebar steps ──
function renderSidebar(activeKey) {
  // Map step keys to sidebar index
  const keyToSidebar = {
    'patient-type': 0,
    'loading':      1,
    'practitioner': 1,
    'service':      1,
    'calendar':     2,
    'timeslots':    3,
    'details':      4,
    'confirmed':    5,
  };
  const activeIdx = keyToSidebar[activeKey] ?? 0;

  // Mobile step label
  if (mobileStep) {
    const labels = ['Patient type', 'Choose service', 'Pick a date', 'Pick a time', 'Your details', 'Confirmed'];
    mobileStep.textContent = `Step ${Math.min(activeIdx + 1, 5)} of 5 — ${labels[activeIdx] || ''}`;
  }

  if (!sideSteps) return;
  sideSteps.innerHTML = STEPS_CONFIG.map((s, i) => {
    const isDone   = i < activeIdx;
    const isActive = i === activeIdx;
    const dotClass = isDone ? 'done' : isActive ? 'active' : '';
    const labelColor = isActive ? 'color:#fff;font-weight:600' : isDone ? 'color:rgba(255,255,255,0.6)' : 'color:rgba(255,255,255,0.35)';
    const dotContent = isDone
      ? `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>`
      : `${i + 1}`;
    return `<div class="bm-sidebar-step ${isActive ? 'active' : ''}">
      <div class="bm-step-dot ${dotClass}">${dotContent}</div>
      <span class="text-sm" style="${labelColor}">${s.label}</span>
    </div>`;
  }).join('');
}

// ── Content helpers ──
function setContent(html) {
  if (content) content.innerHTML = html;
}

function showLoading(msg = 'Just a moment…') {
  currentStep = 'loading';
  renderSidebar('loading');
  setContent(`
    <div class="flex flex-col items-center justify-center py-16 gap-4">
      <div class="bm-spinner"></div>
      <p class="text-gray-500 text-sm">${msg}</p>
    </div>
  `);
}

function showError(msg) {
  setContent(`
    <div class="flex flex-col items-center justify-center py-12 text-center gap-4 px-4">
      <div class="w-14 h-14 rounded-full flex items-center justify-center" style="background:#fef2f2">
        <svg class="w-7 h-7 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      <div>
        <p class="font-semibold text-gray-800 mb-1">Something went wrong</p>
        <p class="text-sm text-gray-500 mb-5">${msg}</p>
      </div>
      <div class="flex gap-3 flex-wrap justify-center">
        <button onclick="window.bmRestart()" class="px-5 py-2.5 rounded-lg text-white text-sm font-medium transition-colors" style="background:#1B3A5C">Try again</button>
        <a href="tel:${phoneFull}" class="px-5 py-2.5 rounded-lg text-sm font-medium border border-gray-200 hover:bg-gray-50 transition-colors" style="color:#1B3A5C">Call ${phone}</a>
      </div>
    </div>
  `);
}

// ── Patient type context badge (shown on all steps after step 1) ──
function buildContextBadge(isNew) {
  if (isNew === null || isNew === undefined) return '';
  const label = isNew
    ? 'New patient — Initial consult ($100)'
    : 'Existing patient — Follow-up ($72)';
  return `<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg mb-5 text-xs font-medium" style="background:rgba(212,168,83,0.1);border:1px solid rgba(212,168,83,0.25);color:#1B3A5C">
    <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#D4A853"></span>
    ${label}
  </div>`;
}

// ── Reset & start ──
function resetAndStart() {
  Object.assign(bm, {
    isNew: null, practiceId: null, customerId: null, csrfKey: null, csrfToken: null,
    practitioners: [], practitionerId: null, practitionerName: '',
    services: [], serviceId: null, serviceName: '', servicePrice: null, serviceDuration: null,
    schedule: [], calMonth: new Date().getMonth() + 1, calYear: new Date().getFullYear(),
    selectedDate: null, selectedDateLabel: '', selectedTime: null, selectedTimeEnd: null, selectedTimeLabel: '',
  });
  showPatientType();
}
window.bmRestart = resetAndStart;

// ── STEP 1: Patient type ──
function showPatientType() {
  currentStep = 'patient-type';
  renderSidebar('patient-type');
  setContent(`
    <div>
      <h2 class="text-2xl font-semibold mb-1" style="color:#1B3A5C">Welcome!</h2>
      <p class="text-gray-500 text-sm mb-7">Are you a new or existing patient at Banora Chiropractic?</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <button class="bm-option-card flex-col text-center py-9 gap-4" data-patient="new">
          <div class="w-16 h-16 rounded-full mx-auto flex items-center justify-center" style="background:rgba(44,95,138,0.08)">
            <svg class="w-8 h-8" style="color:#2C5F8A" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-base" style="color:#1B3A5C">New Patient</div>
            <div class="text-sm text-gray-400 mt-1">First visit to our clinic</div>
          </div>
          <div class="text-xs px-4 py-1.5 rounded-full font-medium" style="background:rgba(212,168,83,0.12);color:#B88E3A">Initial consult — $100</div>
        </button>
        <button class="bm-option-card flex-col text-center py-9 gap-4" data-patient="existing">
          <div class="w-16 h-16 rounded-full mx-auto flex items-center justify-center" style="background:rgba(44,95,138,0.08)">
            <svg class="w-8 h-8" style="color:#2C5F8A" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <div class="font-semibold text-base" style="color:#1B3A5C">Existing Patient</div>
            <div class="text-sm text-gray-400 mt-1">I've visited before</div>
          </div>
          <div class="text-xs px-4 py-1.5 rounded-full font-medium" style="background:rgba(212,168,83,0.12);color:#B88E3A">Follow-up — $72</div>
        </button>
      </div>
      <p class="text-xs text-gray-400 mt-7 text-center">No referral needed · HICAPS health fund claiming available</p>
    </div>
  `);

  content?.querySelectorAll('[data-patient]').forEach(btn => {
    btn.addEventListener('click', () => handlePatientType(btn.dataset.patient === 'new'));
  });
}

// ── Patient type chosen → fetch API ──
async function handlePatientType(isNew) {
  bm.isNew = isNew;
  showLoading('Checking availability…');

  try {
    const practicesRes = await fetch('/api/booking?action=practices');
    const practicesData = await practicesRes.json();
    const pd = practicesData.details || practicesData;
    const allPractices = pd.practices || [];
    const practice = allPractices.find(p =>
      p.name?.toLowerCase().includes('banora') ||
      p.address?.toLowerCase().includes('greenway')
    ) || allPractices[0];
    if (!practice) throw new Error('No practice found');
    bm.practiceId = practice.id;
    bm.customerId = pd.customer_id;

    const detailsRes = await fetch(`/api/booking?action=practice-details&practice_id=${bm.practiceId}`);
    const detailsData = await detailsRes.json();
    const dd = detailsData.details || detailsData;
    bm.csrfKey   = dd.csrf_key;
    bm.csrfToken = dd.csrf_token;
    const rawPractitioners = dd.practioners || dd.practitioners || [];
    // Sort: Dr James Shipway always first
    bm.practitioners = [...rawPractitioners].sort((a, b) => {
      if (a.lastname === 'Shipway') return -1;
      if (b.lastname === 'Shipway') return 1;
      return 0;
    });

    if (bm.practitioners.length === 0) throw new Error('No practitioners found');

    if (bm.practitioners.length === 1) {
      const p = bm.practitioners[0];
      await handlePractitioner(p.id, [p.title, p.firstname, p.lastname].filter(Boolean).join(' ').trim());
    } else {
      showPractitionerStep();
    }
  } catch (err) {
    console.error('[BookingModal] handlePatientType error:', err);
    showError('We couldn\'t load the booking system. Please try again or give us a call.');
  }
}

// ── STEP 2: Practitioner (only if >1) ──
function showPractitionerStep() {
  currentStep = 'practitioner';
  renderSidebar('practitioner');

  // Capture locally — no ambiguity
  const isNew = bm.isNew;

  // Map practitioner photos by lastname
  const photoMap = {
    'Shipway': '/images/dr-james-shipway-v2.webp',
    'Cater':   '/images/dr-paul-cater-v2.webp',
  };

  const cards = bm.practitioners.map(p => {
    const name    = [p.title, p.firstname, p.lastname].filter(Boolean).join(' ').trim();
    const initials = [p.firstname?.[0], p.lastname?.[0]].filter(Boolean).join('').toUpperCase();
    const photo   = photoMap[p.lastname] || null;

    const avatar = photo
      ? `<img src="${photo}" alt="${name}" class="w-16 h-16 rounded-full flex-shrink-0 object-cover object-top border-2" style="border-color:rgba(27,58,92,0.15)" />`
      : `<div class="w-16 h-16 rounded-full flex-shrink-0 flex items-center justify-center text-white font-bold text-lg" style="background:#1B3A5C">${initials}</div>`;

    return `<button class="bm-practitioner-card bm-option-card" data-prac-id="${p.id}" data-prac-name="${name}">
      ${avatar}
      <div class="flex-1 min-w-0 py-1">
        <div class="font-semibold text-base leading-snug" style="color:#1B3A5C">${name}</div>
        <div class="text-sm text-gray-400 mt-0.5">Chiropractor</div>
      </div>
      <svg class="w-5 h-5 flex-shrink-0" style="color:#D4A853" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </button>`;
  }).join('');

  setContent(`
    <div>
      <button class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 mb-6 transition-colors" onclick="window.bmRestart()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back
      </button>
      ${buildContextBadge(isNew)}
      <h2 class="text-2xl font-semibold mb-1.5" style="color:#1B3A5C">Choose your practitioner</h2>
      <p class="text-gray-500 text-sm mb-6">Who would you like to see?</p>
      <div style="display:flex;flex-direction:column;gap:2.5rem">${cards}</div>
    </div>
  `);

  content?.querySelectorAll('[data-prac-id]').forEach(btn => {
    btn.addEventListener('click', () => handlePractitioner(btn.dataset.pracId, btn.dataset.pracName));
  });
}

// ── Practitioner chosen → fetch services ──
async function handlePractitioner(id, name) {
  bm.practitionerId = id;
  bm.practitionerName = name;
  showLoading('Loading services…');

  try {
    const existingParam = !bm.isNew; // true = existing patient, false = new
    const url = `/api/booking?action=practitioner-services&customer_id=${bm.customerId}&practice_id=${bm.practiceId}&practitioner_id=${id}&existing=${existingParam}`;
    const res  = await fetch(url);
    const data = await res.json();
    console.log('[BookingModal] services response:', JSON.stringify(data));
    const svcs = (data.details || data).services || [];
    if (svcs.length === 0) throw new Error('No services found');
    bm.services = svcs;
    showServiceStep();
  } catch (err) {
    console.error('[BookingModal] handlePractitioner error:', err);
    showError('Couldn\'t load services. Please try again or call us.');
  }
}

// ── STEP 3: Service ──
function showServiceStep() {
  currentStep = 'service';
  renderSidebar('service');

  // Capture locally — no ambiguity
  const isNew = bm.isNew;
  const practitionerName = bm.practitionerName;

  const cards = bm.services.map(svc => {
    const price   = svc.fee ? `<span class="text-xl font-bold flex-shrink-0" style="color:#D4A853">$${svc.fee}</span>` : '';
    const svcJson = encodeURIComponent(JSON.stringify(svc));
    return `<button class="bm-option-card" data-svc="${svcJson}">
      <div class="flex-1 min-w-0 py-0.5">
        <div class="font-semibold text-base leading-snug" style="color:#1B3A5C">${svc.desc}</div>
      </div>
      ${price}
      <svg class="w-5 h-5 flex-shrink-0 ml-1" style="color:#D4A853" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>`;
  }).join('');

  const backAction = bm.practitioners.length > 1 ? 'window.bmShowPractitioner()' : 'window.bmRestart()';
  setContent(`
    <div>
      <button class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 mb-6 transition-colors" onclick="${backAction}">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back
      </button>
      ${buildContextBadge(isNew)}
      <h2 class="text-2xl font-semibold mb-1.5" style="color:#1B3A5C">Choose a service</h2>
      <p class="text-gray-500 text-sm mb-6">Seeing <strong>${practitionerName}</strong></p>
      <div class="space-y-4">${cards}</div>
    </div>
  `);

  content?.querySelectorAll('[data-svc]').forEach(btn => {
    btn.addEventListener('click', () => {
      try {
        const svc = JSON.parse(decodeURIComponent(btn.dataset.svc));
        handleService(svc);
      } catch { /* noop */ }
    });
  });
}
window.bmShowPractitioner = showPractitionerStep;

// ── Service chosen → fetch calendar ──
async function handleService(svc) {
  bm.serviceId       = svc.id;
  bm.serviceName     = svc.desc || 'Appointment';
  bm.servicePrice    = svc.fee || null;
  bm.serviceDuration = svc.duration || 45;
  showLoading('Finding available times…');
  await fetchAndShowCalendar(bm.calMonth, bm.calYear);
}

// ── STEP 4: Calendar ──
async function fetchAndShowCalendar(month, year) {
  bm.calMonth = month;
  bm.calYear  = year;
  currentStep = 'calendar';
  renderSidebar('calendar');

  try {
    const url = `/api/booking?action=month-schedule&customer_id=${bm.customerId}&practice_id=${bm.practiceId}&practioner=${bm.practitionerId}&service_item_id=${bm.serviceId}&month=${month}&year=${year}&group=false&new_patient=${bm.isNew}`;
    const res  = await fetch(url);
    const data = await res.json();
    bm.schedule = (data.details || data).schedule || [];
    renderCalendar(year, month, bm.schedule);
  } catch (err) {
    console.error('[BookingModal] fetchAndShowCalendar error:', err);
    showError('Couldn\'t load the calendar. Please try again.');
  }
}

function renderCalendar(year, month, schedule) {
  const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  const DAYS   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

  const firstDay    = new Date(year, month - 1, 1).getDay();
  const daysInMonth = new Date(year, month, 0).getDate();

  // Build availability lookup
  const avail = {};
  (schedule || []).forEach(s => {
    const times = s.time || s.times || [];
    if (times.length > 0) avail[s.day] = times;
  });

  const today = new Date();
  const isPastMonth = (year < today.getFullYear()) || (year === today.getFullYear() && month <= today.getMonth() + 1);
  const prevM = month === 1 ? 12 : month - 1;
  const prevY = month === 1 ? year - 1 : year;
  const nextM = month === 12 ? 1 : month + 1;
  const nextY = month === 12 ? year + 1 : year;

  const dayHeaders = DAYS.map(d => `<div class="text-center text-xs font-medium py-2" style="color:#9ca3af">${d}</div>`).join('');
  const emptyCells = Array(firstDay).fill('<div></div>').join('');

  let dayCells = '';
  for (let d = 1; d <= daysInMonth; d++) {
    if (avail[d]) {
      const dateStr = `${year}-${String(month).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const isSelected = bm.selectedDate === dateStr;
      dayCells += `<button class="bm-cal-day-available${isSelected ? ' selected' : ''}" data-date="${dateStr}" data-day="${d}">${d}</button>`;
    } else {
      dayCells += `<div class="text-center text-sm py-1.5" style="color:#d1d5db">${d}</div>`;
    }
  }

  const availCount = Object.keys(avail).length;
  const availMsg = availCount > 0
    ? `<span style="color:#15803d">${availCount} date${availCount !== 1 ? 's' : ''} available</span>`
    : `<span style="color:#9ca3af">No dates available this month</span>`;

  setContent(`
    <div>
      <button class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 mb-6 transition-colors" onclick="window.bmShowServices()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back
      </button>
      ${buildContextBadge(bm.isNew)}
      <h2 class="text-2xl font-semibold mb-1.5" style="color:#1B3A5C">Choose a date</h2>
      <p class="text-gray-500 text-sm mb-6">${bm.serviceName}${bm.servicePrice ? ` — $${bm.servicePrice}` : ''}</p>

      <div class="rounded-xl border border-gray-100 overflow-hidden" style="background:#fafafa">
        <!-- Calendar header -->
        <div class="flex items-center justify-between px-4 py-3 border-b border-gray-100 bg-white">
          ${!isPastMonth
            ? `<button id="bm-cal-prev" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 transition-colors text-gray-500" data-month="${prevM}" data-year="${prevY}">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
               </button>`
            : '<div class="w-8"></div>'}
          <span class="font-semibold text-sm" style="color:#1B3A5C">${MONTHS[month-1]} ${year}</span>
          <button id="bm-cal-next" class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-gray-100 transition-colors text-gray-500" data-month="${nextM}" data-year="${nextY}">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
        <!-- Calendar grid -->
        <div class="p-3">
          <div class="grid grid-cols-7 gap-1 mb-1">${dayHeaders}</div>
          <div class="grid grid-cols-7 gap-1">${emptyCells}${dayCells}</div>
        </div>
        <div class="px-4 py-2 border-t border-gray-100 text-xs text-center" style="color:#6b7280">${availMsg} — tap a highlighted date</div>
      </div>
    </div>
  `);

  // Bind day buttons
  content?.querySelectorAll('.bm-cal-day-available').forEach(btn => {
    btn.addEventListener('click', () => handleDateSelect(btn.dataset.date, parseInt(btn.dataset.day)));
  });
  // Bind prev/next
  document.getElementById('bm-cal-prev')?.addEventListener('click', (e) => {
    const btn = e.currentTarget;
    fetchAndShowCalendar(parseInt(btn.dataset.month), parseInt(btn.dataset.year));
  });
  document.getElementById('bm-cal-next')?.addEventListener('click', (e) => {
    const btn = e.currentTarget;
    fetchAndShowCalendar(parseInt(btn.dataset.month), parseInt(btn.dataset.year));
  });
}
window.bmShowServices = showServiceStep;

// ── Date selected → STEP 5: Time slots ──
async function handleDateSelect(dateStr, dayNum) {
  bm.selectedDate = dateStr;
  showLoading('Loading available times…');
  currentStep = 'timeslots';
  renderSidebar('timeslots');

  try {
    const url = `/api/booking?action=month-schedule&customer_id=${bm.customerId}&practice_id=${bm.practiceId}&practioner=${bm.practitionerId}&service_item_id=${bm.serviceId}&month=${bm.calMonth}&year=${bm.calYear}&group=false&new_patient=${bm.isNew}`;
    const res  = await fetch(url);
    const data = await res.json();
    const dayEntry = ((data.details || data).schedule || []).find(s => s.day === dayNum);
    const times = dayEntry ? (dayEntry.time || dayEntry.times || []) : [];

    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const [y, mo, d] = dateStr.split('-');
    bm.selectedDateLabel = `${parseInt(d)} ${MONTHS[parseInt(mo)-1]} ${y}`;

    renderTimeSlots(times);
  } catch (err) {
    console.error('[BookingModal] handleDateSelect error:', err);
    showError('Couldn\'t load times for that date. Try another day or call us.');
  }
}

function renderTimeSlots(times) {
  const slots = times.length === 0
    ? `<div class="flex flex-col items-center py-10 text-center gap-3">
        <p class="text-gray-500 text-sm">No available times on this date.</p>
        <button onclick="window.bmGoBackToCalendar()" class="text-sm font-medium px-4 py-2 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors" style="color:#1B3A5C">Choose another date</button>
       </div>`
    : `<div class="grid grid-cols-3 sm:grid-cols-4 gap-2.5">${
        times.map(t => {
          const label = t.start || t;
          const val   = encodeURIComponent(JSON.stringify({ ts: t.ts_start, tsEnd: t.ts_end, label }));
          return `<button class="bm-time-btn" data-time="${val}">${label}</button>`;
        }).join('')
      }</div>`;

  setContent(`
    <div>
      <button class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 mb-6 transition-colors" onclick="window.bmGoBackToCalendar()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back
      </button>
      ${buildContextBadge(bm.isNew)}
      <h2 class="text-2xl font-semibold mb-1.5" style="color:#1B3A5C">Choose a time</h2>
      <p class="text-gray-500 text-sm mb-6">${bm.selectedDateLabel}</p>
      ${slots}
    </div>
  `);

  content?.querySelectorAll('.bm-time-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      try {
        const d = JSON.parse(decodeURIComponent(btn.dataset.time));
        handleTimeSelect(d.ts, d.tsEnd, d.label);
      } catch {
        handleTimeSelect(btn.dataset.time, null, btn.dataset.time);
      }
    });
  });
}
window.bmGoBackToCalendar = () => fetchAndShowCalendar(bm.calMonth, bm.calYear);

// ── Time selected → STEP 6: Details form ──
function handleTimeSelect(ts, tsEnd, label) {
  bm.selectedTime      = ts;
  bm.selectedTimeEnd   = tsEnd;
  bm.selectedTimeLabel = label;
  showDetailsForm();
}

function showDetailsForm() {
  currentStep = 'details';
  renderSidebar('details');

  setContent(`
    <div>
      <button class="flex items-center gap-1.5 text-sm text-gray-400 hover:text-gray-600 mb-6 transition-colors" onclick="window.bmGoBackToCalendar()">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back
      </button>
      ${buildContextBadge(bm.isNew)}
      <h2 class="text-2xl font-semibold mb-1.5" style="color:#1B3A5C">Your details</h2>
      <p class="text-gray-500 text-sm mb-5">Almost there — we just need a few details to confirm your booking.</p>

      <!-- Booking summary pill -->
      <div class="rounded-xl px-4 py-3.5 mb-6 flex flex-wrap gap-x-5 gap-y-1.5 text-sm" style="background:#FFFBF3;border:1.5px solid rgba(212,168,83,0.25)">
        <span class="flex items-center gap-1.5" style="color:#1B3A5C">
          <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#D4A853" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <strong>${bm.selectedDateLabel}</strong> at <strong>${bm.selectedTimeLabel}</strong>
        </span>
        <span class="flex items-center gap-1.5" style="color:#1B3A5C">
          <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#D4A853" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          ${bm.practitionerName}
        </span>
        ${bm.servicePrice ? `<span style="color:#B88E3A;font-weight:600">$${bm.servicePrice}</span>` : ''}
      </div>

      <!-- Form -->
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="bm-label">First name *</label>
            <input id="bm-fn" type="text" placeholder="Jane" class="bm-input" autocomplete="given-name" />
          </div>
          <div>
            <label class="bm-label">Last name *</label>
            <input id="bm-ln" type="text" placeholder="Smith" class="bm-input" autocomplete="family-name" />
          </div>
        </div>
        <div>
          <label class="bm-label">Date of birth * (DD/MM/YYYY)</label>
          <input id="bm-dob" type="text" placeholder="15/06/1985" class="bm-input" maxlength="10" />
        </div>
        <div>
          <label class="bm-label">Email address *</label>
          <input id="bm-email" type="email" placeholder="jane@example.com" class="bm-input" autocomplete="email" />
        </div>
        <div>
          <label class="bm-label">Mobile number *</label>
          <input id="bm-mobile" type="tel" placeholder="0400 000 000" class="bm-input" autocomplete="tel" />
        </div>

        <div id="bm-form-error" class="hidden text-sm text-red-600 bg-red-50 px-4 py-3 rounded-lg"></div>

        <button id="bm-confirm-btn" class="w-full text-white font-semibold py-3.5 rounded-xl transition-colors text-base mt-1" style="background:#1B3A5C">
          Confirm Booking
        </button>
        <p class="text-xs text-gray-400 text-center">Your information is only used for your appointment. HICAPS available at the clinic.</p>
      </div>
    </div>
  `);

  document.getElementById('bm-confirm-btn')?.addEventListener('click', handleConfirm);

  // Auto-format DOB input
  document.getElementById('bm-dob')?.addEventListener('input', (e) => {
    let v = e.target.value.replace(/\D/g, '');
    if (v.length > 2) v = v.slice(0,2) + '/' + v.slice(2);
    if (v.length > 5) v = v.slice(0,5) + '/' + v.slice(5,9);
    e.target.value = v;
  });
}

// ── Confirm booking ──
async function handleConfirm() {
  const fn     = document.getElementById('bm-fn')?.value?.trim();
  const ln     = document.getElementById('bm-ln')?.value?.trim();
  const dob    = document.getElementById('bm-dob')?.value?.trim();
  const email  = document.getElementById('bm-email')?.value?.trim();
  const mobile = document.getElementById('bm-mobile')?.value?.trim();
  const errEl  = document.getElementById('bm-form-error');
  const btn    = document.getElementById('bm-confirm-btn');

  function showFormError(msg) {
    if (errEl) { errEl.textContent = msg; errEl.classList.remove('hidden'); }
  }

  if (!fn || !ln || !dob || !email || !mobile) {
    return showFormError('Please fill in all required fields.');
  }
  if (!/^\d{2}\/\d{2}\/\d{4}$/.test(dob)) {
    return showFormError('Please enter your date of birth as DD/MM/YYYY (e.g. 15/06/1985).');
  }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    return showFormError('Please enter a valid email address.');
  }

  errEl?.classList.add('hidden');
  if (btn) { btn.disabled = true; btn.textContent = 'Confirming…'; btn.style.opacity = '0.7'; }

  const [dobD, dobM, dobY] = dob.split('/');
  const body = {
    practice_id:        bm.practiceId,
    practitioner_id:    bm.practitionerId,
    service_item_id:    bm.serviceId,
    is_group:           "false",
    existing:           bm.isNew ? "false" : "true", // "true" = existing patient, "false" = new
    ts_schedule_start:  bm.selectedTime,
    ts_schedule_end:    bm.selectedTimeEnd,
    customer_firstname: fn,
    customer_lastname:  ln,
    customer_dob:       `${dobY}-${dobM}-${dobD}`,
    customer_email:     email,
    customer_mobile:    mobile,
    csrf_key:           bm.csrfKey,
    csrf_token:         bm.csrfToken,
  };

  try {
    const res  = await fetch('/api/booking', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(body),
    });
    const data = await res.json();
    if (data.success === false) throw new Error(data.message || data.error || 'Booking failed');
    showConfirmation(fn, email);
    if (typeof window.trackEvent === 'function') window.trackEvent('booking_completed');
  } catch (err) {
    console.error('[BookingModal] handleConfirm error:', err.message);
    if (btn) { btn.disabled = false; btn.textContent = 'Confirm Booking'; btn.style.opacity = '1'; }
    showFormError('Something went wrong confirming your booking. Please try again or call us on ' + phone + '.');
  }
}

// ── STEP 7: Confirmation ──
function showConfirmation(firstName, email) {
  currentStep = 'confirmed';
  renderSidebar('confirmed');

  const DAYS_LONG = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const MONTHS    = ['January','February','March','April','May','June','July','August','September','October','November','December'];
  let dateDisplay = bm.selectedDateLabel;
  try {
    const [y, mo, d] = bm.selectedDate.split('-');
    const dayName = DAYS_LONG[new Date(parseInt(y), parseInt(mo)-1, parseInt(d)).getDay()];
    dateDisplay = `${dayName} ${parseInt(d)} ${MONTHS[parseInt(mo)-1]} ${y}`;
  } catch { /* use selectedDateLabel */ }

  setContent(`
    <div class="flex flex-col items-center text-center py-6">
      <div class="w-20 h-20 rounded-full flex items-center justify-center mb-5" style="background:rgba(21,128,61,0.1)">
        <svg class="w-10 h-10" style="color:#15803d" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h2 class="text-2xl font-semibold mb-1.5" style="color:#1B3A5C">You're all booked!</h2>
      <p class="text-gray-500 text-sm mb-7 max-w-xs">A confirmation has been sent to ${email}. We look forward to seeing you, ${firstName}!</p>

      <!-- Appointment card -->
      <div class="w-full max-w-sm rounded-2xl border-2 overflow-hidden text-left" style="border-color:rgba(212,168,83,0.3)">
        <div class="px-5 py-3 text-sm font-semibold text-white" style="background:#1B3A5C">Your Appointment</div>
        <div class="px-5 py-4 space-y-3" style="background:#FFFBF3">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:#D4A853" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <div>
              <div class="text-sm font-semibold" style="color:#1B3A5C">${dateDisplay}</div>
              <div class="text-sm text-gray-500">${bm.selectedTimeLabel}</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:#D4A853" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <div>
              <div class="text-sm font-semibold" style="color:#1B3A5C">${bm.practitionerName}</div>
              <div class="text-sm text-gray-500">${bm.serviceName}${bm.servicePrice ? ` — $${bm.servicePrice}` : ''}</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color:#D4A853" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <div>
              <div class="text-sm font-semibold" style="color:#1B3A5C">Banora Chiropractic</div>
              <div class="text-sm text-gray-500">2/44 Greenway Drive, Tweed Heads South</div>
            </div>
          </div>
        </div>
      </div>

      <button onclick="window.closeBookingModal()" class="mt-7 text-sm font-medium px-6 py-2.5 rounded-lg transition-colors" style="background:#1B3A5C;color:#fff">
        Done
      </button>
    </div>
  `);
}

window.closeBookingModal = closeModal;
</script>
