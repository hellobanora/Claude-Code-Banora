---
import { clinic } from '../../data/clinic';
---

<footer class="bg-navy-deep text-white pb-24 lg:pb-0">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Clinic Info -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/logo.png" alt="Banora Chiropractic logo" class="h-10 w-auto brightness-0 invert" width="100" height="40" />
        </div>
        <p class="text-light-blue-soft/80 text-sm leading-relaxed mb-4">
          Professional chiropractic care for the whole family in Tweed Heads South. Over 30 years of combined experience.
        </p>
        <div class="flex gap-3">
          <a href={clinic.social.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-navy-light rounded-lg flex items-center justify-center hover:bg-mid-blue transition-colors" aria-label="Facebook">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href={clinic.social.instagram} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-navy-light rounded-lg flex items-center justify-center hover:bg-mid-blue transition-colors" aria-label="Instagram">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect width="20" height="20" x="2" y="2" rx="5" ry="5" stroke-width="2"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" stroke-width="2"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke-width="2"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold mb-4">Services</h3>
        <ul class="space-y-2.5">
          <li><a href="/services/chiropractic-adjustments" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Chiropractic Adjustments</a></li>
          <li><a href="/services/posture-correction" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Posture Correction</a></li>
          <li><a href="/services/sports-chiropractic" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Sports Chiropractic</a></li>
          <li><a href="/services/pregnancy-chiropractic" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Pregnancy Chiropractic</a></li>
          <li><a href="/services/paediatric-chiropractic" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Paediatric Chiropractic</a></li>
        </ul>
      </div>

      <!-- Conditions -->
      <div>
        <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold mb-4">Conditions We Help With</h3>
        <ul class="space-y-2.5">
          <li><a href="/conditions/back-pain" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Back Pain</a></li>
          <li><a href="/conditions/neck-pain" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Neck Pain</a></li>
          <li><a href="/conditions/sciatica" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Sciatica</a></li>
          <li><a href="/conditions/headaches-migraines" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Headaches & Migraines</a></li>
          <li><a href="/conditions/shoulder-pain" class="text-sm text-light-blue-soft/80 hover:text-white transition-colors">Shoulder Pain</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-[family-name:var(--font-display)] text-lg font-semibold mb-4">Visit Us</h3>
        <ul class="space-y-3 text-sm text-light-blue-soft/80">
          <li class="flex gap-2">
            <svg class="w-4 h-4 mt-0.5 shrink-0 text-light-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>{clinic.address.full}</span>
          </li>
          <li>
            <a href={`tel:${clinic.phoneFull}`} class="flex gap-2 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0 text-light-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <span>{clinic.phone}</span>
            </a>
          </li>
        </ul>
        <div class="mt-4">
          <h4 class="text-sm font-medium mb-2">Opening Hours</h4>
          <ul class="space-y-1 text-xs text-light-blue-soft/70">
            {clinic.hours.map((h) => (
              <li class="flex justify-between">
                <span>{h.day}</span>
                <span>{h.open === 'Closed' ? 'Closed' : `${h.open} – ${h.close}`}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-navy-light mt-12 pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-xs text-light-blue-soft/60">&copy; {new Date().getFullYear()} {clinic.name}. All rights reserved.</p>
      <div class="flex gap-6 text-xs text-light-blue-soft/60">
        <a href="/blog" class="hover:text-white transition-colors">Blog</a>
        <a href="/patient-resources" class="hover:text-white transition-colors">Patient Resources</a>
        <a href="/forms/index.html" class="hover:text-white transition-colors">Patient Forms</a>
        <a href="/contact" class="hover:text-white transition-colors">Contact</a>
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Book Online</a>
      </div>
    </div>
  </div>
</footer>
