---
import { clinic } from '../../data/clinic';
---

<header class="sticky top-0 z-50 bg-white border-b border-grey-mid/30 transition-shadow duration-300" id="site-header">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[150px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 no-underline">
        <img src="/images/logo-horizontal.png" alt="Banora Chiropractic logo" class="h-32 md:h-48 w-auto" width="480" height="192" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-7" aria-label="Main navigation">
        <a href="/" class="text-sm text-grey-text hover:text-navy transition-colors font-normal">Home</a>
        <a href="/about" class="text-sm text-grey-text hover:text-navy transition-colors font-normal">About</a>
        <div class="relative group">
          <button class="text-sm text-grey-text hover:text-navy transition-colors font-normal flex items-center gap-1">
            Services
            <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-grey-mid/20 py-2 min-w-[220px]">
              <a href="/services/chiropractic-adjustments" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Chiropractic Adjustments</a>
              <a href="/services/posture-correction" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Posture Correction</a>
              <a href="/services/sports-chiropractic" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Sports Chiropractic</a>
              <a href="/services/pregnancy-chiropractic" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Pregnancy Chiropractic</a>
              <a href="/services/paediatric-chiropractic" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Paediatric Chiropractic</a>
            </div>
          </div>
        </div>
        <div class="relative group">
          <button class="text-sm text-grey-text hover:text-navy transition-colors font-normal flex items-center gap-1">
            Conditions
            <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-grey-mid/20 py-2 min-w-[220px]">
              <a href="/conditions/back-pain" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Back Pain</a>
              <a href="/conditions/neck-pain" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Neck Pain</a>
              <a href="/conditions/sciatica" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Sciatica</a>
              <a href="/conditions/headaches-migraines" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Headaches & Migraines</a>
              <a href="/conditions/shoulder-pain" class="block px-4 py-2 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost transition-colors">Shoulder Pain</a>
            </div>
          </div>
        </div>
        <a href="/symptom-checker" class="text-sm text-[var(--color-gold,#D4A853)] hover:text-[var(--color-gold-dark,#B88E3A)] transition-colors font-semibold">Symptom Checker</a>
        <a href="/blog" class="text-sm text-grey-text hover:text-navy transition-colors font-normal">Blog</a>
        <a href="/contact" class="text-sm text-grey-text hover:text-navy transition-colors font-normal">Contact</a>
        <a href="/forms/index.html" class="text-sm text-grey-text hover:text-navy transition-colors font-normal">Patient Forms</a>
      </nav>

      <!-- CTA Buttons -->
      <div class="flex items-center gap-3">
        <a href={`tel:${clinic.phoneFull}`} class="hidden md:flex items-center gap-2 text-sm text-navy font-medium hover:text-mid-blue transition-colors" aria-label="Call us">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {clinic.phone}
        </a>
        <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="book-online-cta bg-mid-blue hover:bg-navy text-white px-6 py-3 rounded-lg text-base font-semibold transition-all duration-200 border-2 border-[#D4A853]">
          Book Online
        </a>

        <!-- Mobile Menu Toggle -->
        <button id="mobile-menu-toggle" class="lg:hidden p-2 text-navy" aria-label="Open menu" aria-expanded="false">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-grey-mid/20">
    <nav class="max-w-7xl mx-auto px-4 py-4 space-y-1" aria-label="Mobile navigation">
      <a href="/" class="block py-3 px-4 text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Home</a>
      <a href="/about" class="block py-3 px-4 text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">About</a>
      <div class="py-2 px-4">
        <span class="text-xs uppercase tracking-wider text-grey-text/60 font-medium">Services</span>
      </div>
      <a href="/services/chiropractic-adjustments" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Chiropractic Adjustments</a>
      <a href="/services/posture-correction" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Posture Correction</a>
      <a href="/services/sports-chiropractic" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Sports Chiropractic</a>
      <a href="/services/pregnancy-chiropractic" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Pregnancy Chiropractic</a>
      <a href="/services/paediatric-chiropractic" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Paediatric Chiropractic</a>
      <div class="py-2 px-4">
        <span class="text-xs uppercase tracking-wider text-grey-text/60 font-medium">Conditions</span>
      </div>
      <a href="/conditions/back-pain" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Back Pain</a>
      <a href="/conditions/neck-pain" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Neck Pain</a>
      <a href="/conditions/sciatica" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Sciatica</a>
      <a href="/conditions/headaches-migraines" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Headaches & Migraines</a>
      <a href="/conditions/shoulder-pain" class="block py-2.5 px-8 text-sm text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Shoulder Pain</a>
      <a href="/symptom-checker" class="block py-3 px-4 text-[var(--color-gold,#D4A853)] font-semibold hover:bg-[var(--color-warm-bg,#FFFBF3)] rounded-lg transition-colors">Symptom Checker</a>
      <a href="/blog" class="block py-3 px-4 text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Blog</a>
      <a href="/contact" class="block py-3 px-4 text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Contact</a>
      <a href="/forms/index.html" class="block py-3 px-4 text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Patient Forms</a>
      <a href="/patient-resources" class="block py-3 px-4 text-grey-text hover:text-navy hover:bg-blue-ghost rounded-lg transition-colors">Patient Resources</a>
      <div class="pt-3 px-4">
        <a href={`tel:${clinic.phoneFull}`} class="flex items-center gap-2 py-3 text-navy font-medium">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {clinic.phone}
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Sticky Mobile Book Now Bar -->
<div class="fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-navy/95 backdrop-blur-sm px-4 py-3 flex items-center justify-between" id="mobile-book-bar">
  <a href={`tel:${clinic.phoneFull}`} class="flex items-center gap-2 text-white text-sm font-medium" aria-label="Call us">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
    Call Now
  </a>
  <a href={clinic.bookingUrl} target="_blank" rel="noopener noreferrer" class="bg-mid-blue hover:bg-light-blue text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition-colors">
    Book Online
  </a>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // Add shadow on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      header?.classList.add('shadow-md');
    } else {
      header?.classList.remove('shadow-md');
    }
  });
</script>
