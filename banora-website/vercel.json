{
  "crons": [
    {
      "path": "/api/cron/health-check",
      "schedule": "0 20 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.banorachiropractic.com.au" }],
      "destination": "https://banorachiropractic.com.au/:path*",
      "permanent": true
    },

    { "source": "/services/${svc.slug}", "destination": "/services/", "permanent": true },
    { "source": "/conditions/${cond.slug}", "destination": "/conditions/", "permanent": true },

    { "source": "/home-2", "destination": "/", "permanent": true },
    { "source": "/home-2/", "destination": "/", "permanent": true },
    { "source": "/page-sitemap.xml", "destination": "/sitemap-index.xml", "permanent": true },

    { "source": "/fees", "destination": "/fees/", "permanent": true },
    { "source": "/conditions", "destination": "/conditions/", "permanent": true },
    { "source": "/services", "destination": "/services/", "permanent": true },
    { "source": "/areas", "destination": "/areas/", "permanent": true },
    { "source": "/about", "destination": "/about/", "permanent": true },
    { "source": "/contact", "destination": "/contact/", "permanent": true },
