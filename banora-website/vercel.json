{
  "crons": [
    {
      "path": "/api/cron/health-check",
      "schedule": "0 20 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "banorachiropractic.com.au" }],
      "destination": "https://www.banorachiropractic.com.au/$1",
      "permanent": true
    },
    { "source": "/book", "destination": "https://www.iconpractice.com/ob/7138/banorachiropractic/245386/2", "permanent": false },
    { "source": "/call", "destination": "tel:+61755992322", "permanent": false },
    { "source": "/about-us", "destination": "/about", "permanent": true },
    { "source": "/about-us/", "destination": "/about", "permanent": true },
    { "source": "/contact-us", "destination": "/contact", "permanent": true },
    { "source": "/contact-us/", "destination": "/contact", "permanent": true },
    { "source": "/new-patients", "destination": "/patient-resources", "permanent": true },
    { "source": "/new-patients/", "destination": "/patient-resources", "permanent": true },
    { "source": "/dr-james-shipway", "destination": "/about", "permanent": true },
    { "source": "/dr-james-shipway/", "destination": "/about", "permanent": true },
    { "source": "/dr-paul-cater", "destination": "/about", "permanent": true },
    { "source": "/dr-paul-cater/", "destination": "/about", "permanent": true },
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/home/", "destination": "/", "permanent": true }
  ]
}
